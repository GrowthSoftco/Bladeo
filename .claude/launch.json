{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Bladeo Dev Server",
      "runtimeExecutable": "/bin/zsh",
      "runtimeArgs": ["-c", "export PATH=/opt/homebrew/bin:$PATH && pnpm dev"],
      "port": 4321
    },
    {
      "name": "Bladeo Preview (built)",
      "runtimeExecutable": "/bin/zsh",
      "runtimeArgs": ["-c", "export PATH=/opt/homebrew/bin:$PATH && pnpm preview"],
      "port": 4321
    }
  ]
}

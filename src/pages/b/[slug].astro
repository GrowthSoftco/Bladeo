---
import '@/styles/global.css';
import { createAdminClient } from '@/lib/supabase';
import BookingWizard from '@/components/public/BookingWizard';

const { slug } = Astro.params;
const admin = createAdminClient();

const { data: barbershop } = await admin
  .from('barbershops')
  .select('*')
  .eq('slug', slug!)
  .maybeSingle();

if (!barbershop) return Astro.redirect('/404');

const [servicesRes, barbersRes] = await Promise.all([
  admin.from('services').select('*').eq('barbershop_id', barbershop.id).eq('is_active', true).order('name'),
  admin.from('members').select('id, display_name, avatar_url, role').eq('barbershop_id', barbershop.id).eq('is_active', true).order('role'),
]);

const services = servicesRes.data ?? [];
const barbers = barbersRes.data ?? [];

function formatCOP(n: number) {
  return '$' + Math.round(n).toLocaleString('es-CO').replace(/,/g, '.');
}
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{barbershop.name} — Reserva tu cita</title>
  <meta name="description" content={`Reserva tu cita en ${barbershop.name}. ${barbershop.description ?? ''}`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body class="min-h-screen bg-[#0a0a0f] text-[#f0f0f5]">

  <!-- Cover image / Hero -->
  <div class="relative overflow-hidden">
    {barbershop.cover_image_url && (
      <div class="absolute inset-0">
        <img src={barbershop.cover_image_url} alt="" class="w-full h-full object-cover opacity-20" />
        <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#0a0a0f]" />
      </div>
    )}
    <div class="absolute inset-0 bg-gradient-to-br from-[#2563eb]/15 via-transparent to-transparent pointer-events-none" />

    <div class="max-w-5xl mx-auto px-4 py-16 text-center relative">
      <!-- Logo -->
      <div class="w-24 h-24 rounded-2xl bg-[#2563eb] flex items-center justify-center mx-auto mb-5 shadow-xl shadow-[#2563eb]/30 overflow-hidden">
        {barbershop.logo_url
          ? <img src={barbershop.logo_url} alt={barbershop.name} class="w-full h-full object-cover" />
          : <span class="text-4xl font-black text-white">{barbershop.name.charAt(0)}</span>
        }
      </div>

      <h1 class="text-4xl sm:text-5xl font-black text-white mb-3">{barbershop.name}</h1>

      {barbershop.description && (
        <p class="text-[#8888a0] text-lg mb-5 max-w-xl mx-auto">{barbershop.description}</p>
      )}

      <div class="flex flex-wrap items-center justify-center gap-5 text-sm text-[#8888a0] mb-8">
        {barbershop.city && (
          <span class="flex items-center gap-1.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            {barbershop.city}{barbershop.address ? ' · ' + barbershop.address : ''}
          </span>
        )}
        {(barbershop.phone || barbershop.whatsapp) && (
          <a href={'https://wa.me/57' + (barbershop.phone || barbershop.whatsapp).replace(/\D/g,'')} target="_blank" rel="noopener" class="flex items-center gap-1.5 hover:text-white transition-colors">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.36 12 19.79 19.79 0 0 1 1.21 3.18 2 2 0 0 1 3.22 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16h0z"/></svg>
            {barbershop.phone || barbershop.whatsapp}
          </a>
        )}
        {barbershop.instagram && (
          <a href={`https://instagram.com/${barbershop.instagram.replace('@','')}`} target="_blank" class="flex items-center gap-1.5 hover:text-white transition-colors">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            {barbershop.instagram}
          </a>
        )}
      </div>

      <!-- Primary CTA -->
      {barbers.length > 0 && services.length > 0 ? (
        <a href="#booking" class="inline-flex items-center gap-2 px-8 py-4 bg-[#2563eb] hover:bg-[#3b82f6] text-white font-bold text-lg rounded-2xl transition-all shadow-lg shadow-[#2563eb]/30 hover:shadow-[#2563eb]/50 hover:-translate-y-0.5">
          Reservar cita ahora
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      ) : barbershop.whatsapp ? (
        <a href={`https://wa.me/57${barbershop.whatsapp.replace(/\D/g,'')}?text=Hola, quiero reservar una cita en ${encodeURIComponent(barbershop.name)}`}
          target="_blank"
          class="inline-flex items-center gap-2 px-8 py-4 bg-[#25d366] hover:bg-[#20bc5a] text-white font-bold text-lg rounded-2xl transition-all">
          Reservar por WhatsApp
        </a>
      ) : null}
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-4 pb-20 space-y-16">

    <!-- Services -->
    {services.length > 0 && (
      <section>
        <h2 class="text-xl font-bold text-white mb-5">Servicios</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {services.map(svc => (
            <div class="bg-[#12121a] border border-[#2a2a3a] rounded-xl px-5 py-4 hover:border-[#2563eb]/40 transition-colors">
              <div class="flex items-start justify-between gap-3">
                <div class="flex-1 min-w-0">
                  <p class="font-semibold text-white">{svc.name}</p>
                  {svc.description && <p class="text-xs text-[#8888a0] mt-0.5">{svc.description}</p>}
                  <p class="text-xs text-[#8888a0] mt-1">{svc.duration_minutes} min</p>
                </div>
                <span class="text-[#2563eb] font-bold text-lg flex-shrink-0">{formatCOP(svc.price)}</span>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Team -->

    <!-- Booking wizard -->
    {barbers.length > 0 && services.length > 0 && (
      <section>
        <BookingWizard
          client:load
          barbershop={{ id: barbershop.id, name: barbershop.name, whatsapp: barbershop.whatsapp }}
          barbers={barbers}
          services={services}
        />
      </section>
    )}

    <!-- WhatsApp fallback if no online booking possible -->
    {(barbers.length === 0 || services.length === 0) && barbershop.whatsapp && (
      <section class="bg-gradient-to-r from-[#2563eb]/20 to-[#7c3aed]/20 border border-[#2563eb]/30 rounded-2xl p-8 text-center">
        <h2 class="text-2xl font-bold text-white mb-2">¿Listo para tu corte?</h2>
        <p class="text-[#8888a0] mb-6">Reserva tu cita directamente con nosotros.</p>
        <a href={`https://wa.me/57${barbershop.whatsapp.replace(/\D/g,'')}?text=Hola, quiero reservar una cita en ${encodeURIComponent(barbershop.name)}`}
          target="_blank"
          class="inline-flex items-center gap-2 px-6 py-3 bg-[#25d366] hover:bg-[#20bc5a] text-white font-semibold rounded-xl transition-colors">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Escribir por WhatsApp
        </a>
      </section>
    )}

    <!-- Footer -->
    <div class="text-center">
      <p class="text-xs text-[#8888a0]">
        Agenda con
        <a href="/" class="text-[#2563eb] hover:text-[#3b82f6] font-medium ml-1">Bladeo</a>
      </p>
    </div>
  </div>
</body>
</html>

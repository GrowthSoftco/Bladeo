 ---
import AuthLayout from '@/layouts/AuthLayout.astro';
import { createServerClient } from '@/lib/supabase';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/login');
}

const supabase = createServerClient(Astro.cookies);
const { data: member, error: memberError } = await supabase
  .from('members')
  .select('id')
  .eq('user_id', user.id)
  .single();

if (member) {
  return Astro.redirect('/app/plans');
}

if (memberError && memberError.code !== 'PGRST116') {
  console.error('Onboarding member check error:', memberError);
}
---

<AuthLayout title="Completa tu barbería">
  <div>
    <h2 class="text-2xl font-bold text-white mb-1">Completa tu barbería</h2>
    <p class="text-[#8888a0] mb-8">Tu cuenta está lista. Solo falta asociarla a tu barbería.</p>

    <div id="error-banner" class="hidden mb-5 px-4 py-3 bg-danger/10 border border-danger/30 rounded-lg text-danger text-sm"></div>

    <form id="onboarding-form" class="space-y-5">
      <div>
        <label for="owner-name" class="block text-sm font-medium text-[#f0f0f5] mb-1.5">Tu nombre</label>
        <input type="text" id="owner-name" name="owner-name" required placeholder="Juan Pérez"
          class="w-full px-4 py-3 bg-[#1a1a25] border border-[#2a2a3a] rounded-lg text-white placeholder-[#8888a0] focus:outline-none focus:border-brand transition-colors" />
      </div>

      <div>
        <label for="shop-name" class="block text-sm font-medium text-[#f0f0f5] mb-1.5">Nombre de la barbería</label>
        <input type="text" id="shop-name" name="shop-name" required placeholder="Classic Cuts Barbershop"
          class="w-full px-4 py-3 bg-[#1a1a25] border border-[#2a2a3a] rounded-lg text-white placeholder-[#8888a0] focus:outline-none focus:border-brand transition-colors" />
        <p class="mt-1 text-xs text-[#8888a0]">Tu barbería estará disponible en: bladeo.app/b/<span id="slug-preview">tu-barberia</span></p>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="phone" class="block text-sm font-medium text-[#f0f0f5] mb-1.5">Teléfono</label>
          <input type="tel" id="phone" name="phone" placeholder="300 123 4567"
            class="w-full px-4 py-3 bg-[#1a1a25] border border-[#2a2a3a] rounded-lg text-white placeholder-[#8888a0] focus:outline-none focus:border-brand transition-colors" />
        </div>
        <div>
          <label for="city" class="block text-sm font-medium text-[#f0f0f5] mb-1.5">Ciudad</label>
          <input type="text" id="city" name="city" value="Pereira" placeholder="Pereira"
            class="w-full px-4 py-3 bg-[#1a1a25] border border-[#2a2a3a] rounded-lg text-white placeholder-[#8888a0] focus:outline-none focus:border-brand transition-colors" />
        </div>
      </div>

      <button type="submit" id="create-btn" class="w-full py-3 px-6 bg-brand hover:bg-brand-light text-white font-semibold rounded-lg transition-colors flex items-center justify-center gap-2 disabled:opacity-60">
        <span id="create-text">Crear barbería</span>
        <span id="create-spinner" class="hidden">
          <svg class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
        </span>
      </button>
    </form>
  </div>
</AuthLayout>

<script>
  const form = document.getElementById('onboarding-form');
  const createBtn = document.getElementById('create-btn');
  const createText = document.getElementById('create-text');
  const createSpinner = document.getElementById('create-spinner');
  const errorBanner = document.getElementById('error-banner');
  const shopName = document.getElementById('shop-name');
  const slugPreview = document.getElementById('slug-preview');

  function slugify(text) {
    return text
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .replace(/[^a-z0-9\s-]/g, '')
      .trim()
      .replace(/\s+/g, '-')
      .replace(/-+/g, '-');
  }

  shopName.addEventListener('input', () => {
    slugPreview.textContent = slugify(shopName.value) || 'tu-barberia';
  });

  form.addEventListener('submit', async (event) => {
    event.preventDefault();
    errorBanner.classList.add('hidden');
    createBtn.disabled = true;
    createText.textContent = 'Creando barbería...';
    createSpinner.classList.remove('hidden');

    const ownerName = (document.getElementById('owner-name')).value;
    const shopNameVal = (document.getElementById('shop-name')).value;
    const phone = (document.getElementById('phone')).value;
    const city = (document.getElementById('city')).value;

    try {
      const res = await fetch('/api/auth/complete-profile', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ownerName, shopName: shopNameVal, phone, city }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Error al crear la barbería.');
      window.location.href = '/app/plans';
    } catch (err) {
      errorBanner.textContent = err.message || 'Ocurrió un error inesperado.';
      errorBanner.classList.remove('hidden');
      createBtn.disabled = false;
      createText.textContent = 'Crear barbería';
      createSpinner.classList.add('hidden');
    }
  });
</script>

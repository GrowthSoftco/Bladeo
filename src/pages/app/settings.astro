---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import type { Barbershop, Subscription } from '@/lib/types';
import { PLAN_NAMES } from '@/lib/stripe-config';
import { formatDate } from '@/lib/utils';
import NotificationSoundPicker from '@/components/dashboard/NotificationSoundPicker';

const barbershop = Astro.locals.barbershop as Barbershop;
const subscription = Astro.locals.subscription as Subscription;

const tierName = PLAN_NAMES[subscription?.tier ?? (subscription as any)?.plan_name ?? 'basic'];

const bankingEnabled = barbershop?.is_banking_correspondent === true;
---

<DashboardLayout title="Configuración">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-white mb-1">Configuración</h1>
    <p class="text-[var(--color-text-secondary)]">Configura los detalles de tu barbería</p>
  </div>

  <div class="max-w-2xl space-y-6">
    <!-- Barbershop profile -->
    <div class="bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-xl p-6">
      <h2 class="font-semibold text-white mb-5">Perfil de la barbería</h2>
      <form class="space-y-4" id="profile-form">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-[var(--color-text-primary)] mb-1.5">Nombre</label>
            <input type="text" name="name" value={barbershop.name} required class="w-full px-4 py-2.5 bg-[var(--color-surface-overlay)] border border-[var(--color-border)] rounded-lg text-white focus:outline-none focus:border-[var(--color-brand)] text-sm transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium text-[var(--color-text-primary)] mb-1.5">Slug (URL pública)</label>
            <div class="flex">
              <span class="px-3 py-2.5 bg-[var(--color-surface)] border border-r-0 border-[var(--color-border)] rounded-l-lg text-[var(--color-text-secondary)] text-xs flex items-center">/b/</span>
              <input type="text" name="slug" id="slug-input" value={barbershop.slug} required
                pattern="[a-z0-9\-]+"
                title="Solo letras minúsculas, números y guiones"
                class="flex-1 px-4 py-2.5 bg-[var(--color-surface-overlay)] border border-[var(--color-border)] rounded-r-lg text-white focus:outline-none focus:border-[var(--color-brand)] text-sm transition-colors" />
            </div>
            <p class="text-[var(--color-text-secondary)] text-xs mt-1">Solo minúsculas, números y guiones. Ej: <span class="text-white">mi-barberia</span></p>
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-[var(--color-text-primary)] mb-1.5">Descripción</label>
          <textarea name="description" rows={3} class="w-full px-4 py-2.5 bg-[var(--color-surface-overlay)] border border-[var(--color-border)] rounded-lg text-white focus:outline-none focus:border-[var(--color-brand)] text-sm transition-colors resize-none">{barbershop.description ?? ''}</textarea>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-[var(--color-text-primary)] mb-1.5">Teléfono</label>
            <input type="tel" name="phone" value={barbershop.phone ?? ''} class="w-full px-4 py-2.5 bg-[var(--color-surface-overlay)] border border-[var(--color-border)] rounded-lg text-white focus:outline-none focus:border-[var(--color-brand)] text-sm transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium text-[var(--color-text-primary)] mb-1.5">WhatsApp</label>
            <input type="tel" name="whatsapp" value={barbershop.whatsapp ?? ''} class="w-full px-4 py-2.5 bg-[var(--color-surface-overlay)] border border-[var(--color-border)] rounded-lg text-white focus:outline-none focus:border-[var(--color-brand)] text-sm transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium text-[var(--color-text-primary)] mb-1.5">Instagram</label>
            <input type="text" name="instagram" value={barbershop.instagram ?? ''} placeholder="@tu_barberia" class="w-full px-4 py-2.5 bg-[var(--color-surface-overlay)] border border-[var(--color-border)] rounded-lg text-white focus:outline-none focus:border-[var(--color-brand)] text-sm transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium text-[var(--color-text-primary)] mb-1.5">Ciudad</label>
            <input type="text" name="city" value={barbershop.city} class="w-full px-4 py-2.5 bg-[var(--color-surface-overlay)] border border-[var(--color-border)] rounded-lg text-white focus:outline-none focus:border-[var(--color-brand)] text-sm transition-colors" />
          </div>
          <div class="sm:col-span-2">
            <label class="block text-sm font-medium text-[var(--color-text-primary)] mb-1.5">Dirección</label>
            <input type="text" name="address" value={barbershop.address ?? ''} class="w-full px-4 py-2.5 bg-[var(--color-surface-overlay)] border border-[var(--color-border)] rounded-lg text-white focus:outline-none focus:border-[var(--color-brand)] text-sm transition-colors" />
          </div>
        </div>
        <div class="flex items-center justify-between pt-2">
          <a href={`/b/${barbershop.slug}`} target="_blank" class="text-sm text-[var(--color-brand)] hover:text-[var(--color-brand-light)] transition-colors">
            Ver perfil público →
          </a>
          <button type="submit" class="px-5 py-2.5 bg-[var(--color-brand)] hover:bg-[var(--color-brand-light)] text-white text-sm font-semibold rounded-lg transition-colors">
            Guardar cambios
          </button>
        </div>
      </form>
    </div>

    <!-- Subscription -->
    <div class="bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-xl p-6">
      <h2 class="font-semibold text-white mb-5">Suscripción</h2>
      <div class="flex items-center justify-between mb-4">
        <div>
          <p class="text-white font-medium">Plan {tierName}</p>
          <p class="text-[var(--color-text-secondary)] text-sm">
            {subscription?.current_period_end
              ? `Próximo cobro: ${formatDate(subscription.current_period_end)}`
              : 'Sin suscripción activa'}
          </p>
        </div>
        <span class={`text-xs font-medium px-2.5 py-1 rounded-full border ${subscription?.status === 'active' ? 'bg-[#22c55e]/20 text-[#22c55e] border-[#22c55e]/30' : 'bg-[#f59e0b]/20 text-[#f59e0b] border-[#f59e0b]/30'}`}>
          {subscription?.status === 'active' ? 'Activa' : subscription?.status ?? 'Inactiva'}
        </span>
      </div>
      <div class="flex gap-3">
        <button id="open-portal-btn" class="px-4 py-2 bg-[var(--color-surface-overlay)] hover:bg-[var(--color-surface-overlay)] border border-[var(--color-border)] text-white text-sm font-medium rounded-lg transition-colors">
          Cambiar plan
        </button>
        <button id="cancel-portal-btn" class="px-4 py-2 bg-[var(--color-surface-overlay)] hover:bg-[var(--color-surface-overlay)] border border-[var(--color-border)] text-[var(--color-text-secondary)] hover:text-white text-sm font-medium rounded-lg transition-colors">
          Cancelar suscripción
        </button>
      </div>
    </div>

    <!-- Tema de color -->
    <div class="bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-xl p-6" id="theme-card">
      <h2 class="font-semibold text-white mb-1">Tema de color</h2>
      <p class="text-[var(--color-text-secondary)] text-sm mb-5">Elige el tema visual de tu panel de control</p>

      <p class="text-xs font-semibold text-[var(--color-text-secondary)] uppercase tracking-wider mb-3">Oscuro</p>
      <div class="grid grid-cols-3 sm:grid-cols-6 gap-3 mb-5">
        <button onclick="applyTheme('dark-azul')"    data-theme="dark-azul"    class="theme-btn group flex flex-col items-center gap-2 p-2 rounded-xl border-2 border-transparent hover:border-[#2563eb]/50 transition-all">
          <div class="w-full h-10 rounded-lg overflow-hidden flex shadow-sm"><div class="w-1/3 h-full" style="background:#12121a"></div><div class="w-1/3 h-full flex items-center justify-center" style="background:#0a0a0f"><div class="w-3 h-3 rounded-full" style="background:#2563eb"></div></div><div class="w-1/3 h-full" style="background:#1a1a25"></div></div>
          <span class="text-[11px] font-medium text-[var(--color-text-secondary)] group-hover:text-white transition-colors">Azul</span>
        </button>
        <button onclick="applyTheme('dark-morado')"  data-theme="dark-morado"  class="theme-btn group flex flex-col items-center gap-2 p-2 rounded-xl border-2 border-transparent hover:border-[#7c3aed]/50 transition-all">
          <div class="w-full h-10 rounded-lg overflow-hidden flex shadow-sm"><div class="w-1/3 h-full" style="background:#12121a"></div><div class="w-1/3 h-full flex items-center justify-center" style="background:#0a0a0f"><div class="w-3 h-3 rounded-full" style="background:#7c3aed"></div></div><div class="w-1/3 h-full" style="background:#1a1025"></div></div>
          <span class="text-[11px] font-medium text-[var(--color-text-secondary)] group-hover:text-white transition-colors">Morado</span>
        </button>
        <button onclick="applyTheme('dark-verde')"   data-theme="dark-verde"   class="theme-btn group flex flex-col items-center gap-2 p-2 rounded-xl border-2 border-transparent hover:border-[#16a34a]/50 transition-all">
          <div class="w-full h-10 rounded-lg overflow-hidden flex shadow-sm"><div class="w-1/3 h-full" style="background:#101a10"></div><div class="w-1/3 h-full flex items-center justify-center" style="background:#0a0f0a"><div class="w-3 h-3 rounded-full" style="background:#16a34a"></div></div><div class="w-1/3 h-full" style="background:#182518"></div></div>
          <span class="text-[11px] font-medium text-[var(--color-text-secondary)] group-hover:text-white transition-colors">Verde</span>
        </button>
        <button onclick="applyTheme('dark-naranja')" data-theme="dark-naranja" class="theme-btn group flex flex-col items-center gap-2 p-2 rounded-xl border-2 border-transparent hover:border-[#ea580c]/50 transition-all">
          <div class="w-full h-10 rounded-lg overflow-hidden flex shadow-sm"><div class="w-1/3 h-full" style="background:#1a1208"></div><div class="w-1/3 h-full flex items-center justify-center" style="background:#0f0a06"><div class="w-3 h-3 rounded-full" style="background:#ea580c"></div></div><div class="w-1/3 h-full" style="background:#251c0e"></div></div>
          <span class="text-[11px] font-medium text-[var(--color-text-secondary)] group-hover:text-white transition-colors">Naranja</span>
        </button>
        <button onclick="applyTheme('dark-carbon')"  data-theme="dark-carbon"  class="theme-btn group flex flex-col items-center gap-2 p-2 rounded-xl border-2 border-transparent hover:border-[#6366f1]/50 transition-all">
          <div class="w-full h-10 rounded-lg overflow-hidden flex shadow-sm"><div class="w-1/3 h-full" style="background:#0f0f14"></div><div class="w-1/3 h-full flex items-center justify-center" style="background:#060608"><div class="w-3 h-3 rounded-full" style="background:#6366f1"></div></div><div class="w-1/3 h-full" style="background:#16161e"></div></div>
          <span class="text-[11px] font-medium text-[var(--color-text-secondary)] group-hover:text-white transition-colors">Carbón</span>
        </button>
        <button onclick="applyTheme('dark-slate')"   data-theme="dark-slate"   class="theme-btn group flex flex-col items-center gap-2 p-2 rounded-xl border-2 border-transparent hover:border-[#38bdf8]/50 transition-all">
          <div class="w-full h-10 rounded-lg overflow-hidden flex shadow-sm"><div class="w-1/3 h-full" style="background:#0f1520"></div><div class="w-1/3 h-full flex items-center justify-center" style="background:#080c10"><div class="w-3 h-3 rounded-full" style="background:#38bdf8"></div></div><div class="w-1/3 h-full" style="background:#162030"></div></div>
          <span class="text-[11px] font-medium text-[var(--color-text-secondary)] group-hover:text-white transition-colors">Slate</span>
        </button>
      </div>

      <p class="text-xs font-semibold text-[var(--color-text-secondary)] uppercase tracking-wider mb-3">Claro</p>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <button onclick="applyTheme('light-blanco')" data-theme="light-blanco" class="theme-btn group flex flex-col items-center gap-2 p-2 rounded-xl border-2 border-[#e0e4f0] hover:border-[#2563eb]/60 transition-all">
          <div class="w-full h-10 rounded-lg overflow-hidden flex shadow-sm border border-[#d4d9f0]"><div class="w-1/3 h-full" style="background:#eef1fb"></div><div class="w-1/3 h-full flex items-center justify-center" style="background:#f5f7ff"><div class="w-3 h-3 rounded-full" style="background:#2563eb"></div></div><div class="w-1/3 h-full" style="background:#ffffff"></div></div>
          <span class="text-[11px] font-medium text-[#5060a0] group-hover:text-[var(--color-brand)] transition-colors">Blanco</span>
        </button>
        <button onclick="applyTheme('light-gris')"   data-theme="light-gris"   class="theme-btn group flex flex-col items-center gap-2 p-2 rounded-xl border-2 border-[#e0e0ea] hover:border-[#7c3aed]/60 transition-all">
          <div class="w-full h-10 rounded-lg overflow-hidden flex shadow-sm border border-[#d0d0de]"><div class="w-1/3 h-full" style="background:#ebebf2"></div><div class="w-1/3 h-full flex items-center justify-center" style="background:#f2f2f5"><div class="w-3 h-3 rounded-full" style="background:#7c3aed"></div></div><div class="w-1/3 h-full" style="background:#ffffff"></div></div>
          <span class="text-[11px] font-medium text-[#606075] group-hover:text-[#7c3aed] transition-colors">Gris</span>
        </button>
        <button onclick="applyTheme('light-crema')"  data-theme="light-crema"  class="theme-btn group flex flex-col items-center gap-2 p-2 rounded-xl border-2 border-[#e8d5b0] hover:border-[#b45309]/60 transition-all">
          <div class="w-full h-10 rounded-lg overflow-hidden flex shadow-sm border border-[#e0d0b8]"><div class="w-1/3 h-full" style="background:#f5ede0"></div><div class="w-1/3 h-full flex items-center justify-center" style="background:#fdf8f0"><div class="w-3 h-3 rounded-full" style="background:#b45309"></div></div><div class="w-1/3 h-full" style="background:#ffffff"></div></div>
          <span class="text-[11px] font-medium text-[#806040] group-hover:text-[#b45309] transition-colors">Crema</span>
        </button>
        <button onclick="applyTheme('light-menta')"  data-theme="light-menta"  class="theme-btn group flex flex-col items-center gap-2 p-2 rounded-xl border-2 border-[#b8e0da] hover:border-[#0d9488]/60 transition-all">
          <div class="w-full h-10 rounded-lg overflow-hidden flex shadow-sm border border-[#b8e0da]"><div class="w-1/3 h-full" style="background:#e0f5f0"></div><div class="w-1/3 h-full flex items-center justify-center" style="background:#f0faf8"><div class="w-3 h-3 rounded-full" style="background:#0d9488"></div></div><div class="w-1/3 h-full" style="background:#ffffff"></div></div>
          <span class="text-[11px] font-medium text-[#407070] group-hover:text-[#0d9488] transition-colors">Menta</span>
        </button>
      </div>

      <div id="theme-saved-msg" class="hidden mt-4 text-sm text-green-400">✓ Tema guardado</div>
    </div>

    <!-- Corresponsal bancario toggle -->
    <div class="bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-xl p-6" id="banking-card">
      <div class="flex items-start justify-between">
        <div class="flex-1">
          <h2 class="font-semibold text-white mb-1">Corresponsal Bancario</h2>
          <p class="text-[var(--color-text-secondary)] text-sm">Activa el módulo de corresponsal para registrar transacciones bancarias.</p>
          <p id="banking-status-text" class={`text-xs mt-2 font-medium ${bankingEnabled ? 'text-green-400' : 'text-[var(--color-text-secondary)]'}`}>
            {bankingEnabled ? '✓ Activado' : 'Inactivo'}
          </p>
        </div>
        <div class="flex flex-col items-end gap-2 ml-4 flex-shrink-0">
          <label class="relative inline-flex items-center cursor-pointer">
            <input type="checkbox" id="banking-toggle" class="sr-only peer" checked={bankingEnabled} />
            <div class="w-11 h-6 bg-[var(--color-border)] peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:bg-[var(--color-brand)] after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all"></div>
          </label>
          <span id="banking-saving" class="text-xs text-[var(--color-text-secondary)] hidden">Guardando...</span>
        </div>
      </div>
    </div>

    <!-- Cambiar contraseña -->
    <div class="bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-xl p-6">
      <h2 class="font-semibold text-white mb-1">Seguridad</h2>
      <p class="text-[var(--color-text-secondary)] text-sm mb-5">Cambia tu contraseña de acceso</p>
      <form class="space-y-4" id="password-form">
        <div>
          <label class="block text-sm font-medium text-[var(--color-text-primary)] mb-1.5">Nueva contraseña</label>
          <div class="relative">
            <input type="password" id="new-password" minlength="6" required placeholder="Mínimo 6 caracteres"
              class="w-full px-4 py-2.5 bg-[var(--color-surface-overlay)] border border-[var(--color-border)] rounded-lg text-white focus:outline-none focus:border-[var(--color-brand)] text-sm pr-10 transition-colors" />
            <button type="button" id="toggle-new-pass" class="absolute right-3 top-1/2 -translate-y-1/2 text-[var(--color-text-secondary)] hover:text-white">
              <svg id="eye-icon-new" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-[var(--color-text-primary)] mb-1.5">Confirmar contraseña</label>
          <div class="relative">
            <input type="password" id="confirm-password" minlength="6" required placeholder="Repite la contraseña"
              class="w-full px-4 py-2.5 bg-[var(--color-surface-overlay)] border border-[var(--color-border)] rounded-lg text-white focus:outline-none focus:border-[var(--color-brand)] text-sm pr-10 transition-colors" />
            <button type="button" id="toggle-confirm-pass" class="absolute right-3 top-1/2 -translate-y-1/2 text-[var(--color-text-secondary)] hover:text-white">
              <svg id="eye-icon-confirm" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
        </div>
        <div id="password-error" class="hidden text-sm text-red-400 bg-red-500/10 border border-red-500/20 rounded-lg px-3 py-2"></div>
        <div id="password-success" class="hidden text-sm text-green-400 bg-green-500/10 border border-green-500/20 rounded-lg px-3 py-2">✓ Contraseña actualizada correctamente</div>
        <div class="flex justify-end">
          <button type="submit" id="password-submit-btn"
            class="px-5 py-2.5 bg-[var(--color-brand)] hover:bg-[var(--color-brand-light)] text-white text-sm font-semibold rounded-lg transition-colors disabled:opacity-60">
            Cambiar contraseña
          </button>
        </div>
      </form>
    </div>

    <!-- Notification sound -->
    <NotificationSoundPicker client:load />

  </div>
</DashboardLayout>

<script define:vars={{ barbershopId: barbershop.id }}>
  // Slug sanitization: lowercase, spaces→hyphens, strip non-alphanumeric except hyphens
  function sanitizeSlug(val) {
    return val
      .toLowerCase()
      .normalize('NFD').replace(/[̀-ͯ]/g, '') // remove accents
      .replace(/\s+/g, '-')
      .replace(/[^a-z0-9\-]/g, '')
      .replace(/-+/g, '-')
      .replace(/^-|-$/g, '');
  }

  var slugInput = document.getElementById('slug-input');
  if (slugInput) {
    slugInput.addEventListener('input', function() {
      var sanitized = sanitizeSlug(slugInput.value);
      if (slugInput.value !== sanitized) slugInput.value = sanitized;
    });
    slugInput.addEventListener('blur', function() {
      slugInput.value = sanitizeSlug(slugInput.value);
    });
  }

  // Profile form
  var profileForm = document.getElementById('profile-form');
  if (profileForm) {
    profileForm.addEventListener('submit', function(e) {
      e.preventDefault();
      var form = e.target;
      var btn = form.querySelector('button[type="submit"]');
      var originalText = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Guardando...';

      var formData = new FormData(form);
      var body = Object.fromEntries(formData.entries());

      // Sanitize slug before sending
      if (body.slug) body.slug = sanitizeSlug(String(body.slug));

      if (!body.slug) {
        alert('El slug no puede estar vacío.');
        btn.disabled = false;
        btn.textContent = originalText;
        return;
      }

      fetch('/api/barbershops/' + barbershopId, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      })
        .then(function(res) { return res.json().then(function(d) { return { ok: res.ok, d: d }; }); })
        .then(function(result) {
          if (result.ok) {
            // Update slug input with whatever DB returned
            if (result.d.slug && slugInput) slugInput.value = result.d.slug;
            btn.textContent = '¡Guardado!';
            btn.classList.replace('bg-[var(--color-brand)]', 'bg-green-600');
            setTimeout(function() {
              btn.textContent = originalText;
              btn.classList.replace('bg-green-600', 'bg-[var(--color-brand)]');
              btn.disabled = false;
            }, 2000);
          } else {
            alert(result.d.error || 'Error al guardar');
            btn.disabled = false;
            btn.textContent = originalText;
          }
        });
    });
  }

  // Banking correspondent toggle
  var bankingToggle = document.getElementById('banking-toggle');
  if (bankingToggle) {
    bankingToggle.addEventListener('change', function(e) {
      var checked = e.target.checked;
      var savingEl = document.getElementById('banking-saving');
      var statusEl = document.getElementById('banking-status-text');
      var card = document.getElementById('banking-card');

      if (savingEl) { savingEl.textContent = 'Guardando...'; savingEl.classList.remove('hidden'); }

      fetch('/api/barbershops/' + barbershopId, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ is_banking_correspondent: checked }),
      })
        .then(function(res) { return res.json().then(function(d) { return { ok: res.ok, d: d }; }); })
        .then(function(result) {
          if (savingEl) savingEl.classList.add('hidden');
          if (result.ok) {
            if (statusEl) {
              statusEl.textContent = checked ? '✓ Activado' : 'Inactivo';
              statusEl.className = 'text-xs mt-2 font-medium ' + (checked ? 'text-green-400' : 'text-[var(--color-text-secondary)]');
            }
            if (card) card.style.borderColor = checked ? 'rgba(34,197,94,0.3)' : '';
          } else {
            e.target.checked = !checked;
            alert('Error: ' + (result.d.error || 'No se pudo guardar'));
          }
        })
        .catch(function() {
          if (savingEl) savingEl.classList.add('hidden');
          e.target.checked = !checked;
          alert('Error de conexion');
        });
    });
  }

  // Theme picker — highlight active theme and wire up buttons
  (function() {
    var saved = localStorage.getItem('bladeo_theme') || 'dark-azul';
    var migrate = { 'azul':'dark-azul','morado':'dark-morado','verde':'dark-verde','naranja':'dark-naranja','rosa':'dark-azul','cian':'dark-azul' };
    if (migrate[saved]) saved = migrate[saved];

    function highlightTheme(name) {
      document.querySelectorAll('.theme-btn').forEach(function(btn) {
        var tn = btn.getAttribute('data-theme');
        btn.style.borderColor = '';
        btn.style.boxShadow = '';
        if (tn === name) {
          // determine accent color from the dot inside
          var dot = btn.querySelector('.rounded-full');
          var accent = dot ? dot.style.background : '#2563eb';
          btn.style.borderColor = accent;
          btn.style.boxShadow = '0 0 0 1px ' + accent;
        }
      });
    }

    highlightTheme(saved);

    // Override applyTheme to also show saved msg
    var _orig = window.applyTheme;
    window.applyTheme = function(name) {
      if (_orig) _orig(name);
      highlightTheme(name);
      var msg = document.getElementById('theme-saved-msg');
      if (msg) {
        msg.classList.remove('hidden');
        setTimeout(function() { msg.classList.add('hidden'); }, 2000);
      }
    };
  })();

  // Password change form
  var passwordForm = document.getElementById('password-form');
  if (passwordForm) {
    // Toggle show/hide for new password
    document.getElementById('toggle-new-pass')?.addEventListener('click', function() {
      var inp = document.getElementById('new-password');
      inp.type = inp.type === 'password' ? 'text' : 'password';
    });
    document.getElementById('toggle-confirm-pass')?.addEventListener('click', function() {
      var inp = document.getElementById('confirm-password');
      inp.type = inp.type === 'password' ? 'text' : 'password';
    });

    passwordForm.addEventListener('submit', function(e) {
      e.preventDefault();
      var newPass = document.getElementById('new-password').value;
      var confirmPass = document.getElementById('confirm-password').value;
      var errorEl = document.getElementById('password-error');
      var successEl = document.getElementById('password-success');
      var btn = document.getElementById('password-submit-btn');

      errorEl.classList.add('hidden');
      successEl.classList.add('hidden');

      if (newPass !== confirmPass) {
        errorEl.textContent = 'Las contraseñas no coinciden.';
        errorEl.classList.remove('hidden');
        return;
      }
      if (newPass.length < 6) {
        errorEl.textContent = 'La contraseña debe tener al menos 6 caracteres.';
        errorEl.classList.remove('hidden');
        return;
      }

      btn.disabled = true;
      btn.textContent = 'Guardando...';

      fetch('/api/auth/change-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ password: newPass }),
      })
        .then(function(res) { return res.json().then(function(d) { return { ok: res.ok, d: d }; }); })
        .then(function(result) {
          if (result.ok) {
            successEl.classList.remove('hidden');
            passwordForm.reset();
          } else {
            errorEl.textContent = result.d.error || 'Error al cambiar la contraseña.';
            errorEl.classList.remove('hidden');
          }
        })
        .catch(function() {
          errorEl.textContent = 'Error de conexión. Intenta de nuevo.';
          errorEl.classList.remove('hidden');
        })
        .finally(function() {
          btn.disabled = false;
          btn.textContent = 'Cambiar contraseña';
        });
    });
  }

  // Stripe portal buttons
  var openPortalBtn = document.getElementById('open-portal-btn');
  if (openPortalBtn) {
    openPortalBtn.addEventListener('click', function() {
      openPortalBtn.disabled = true;
      openPortalBtn.textContent = 'Cargando...';
      fetch('/api/stripe/create-portal', { method: 'POST' })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          if (d.url) window.location.href = d.url;
          else { openPortalBtn.disabled = false; openPortalBtn.textContent = 'Cambiar plan'; }
        });
    });
  }

  var cancelPortalBtn = document.getElementById('cancel-portal-btn');
  if (cancelPortalBtn) {
    cancelPortalBtn.addEventListener('click', function() {
      cancelPortalBtn.disabled = true;
      cancelPortalBtn.textContent = 'Cargando...';
      fetch('/api/stripe/create-portal', { method: 'POST' })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          if (d.url) window.location.href = d.url;
          else { cancelPortalBtn.disabled = false; cancelPortalBtn.textContent = 'Cancelar suscripcion'; }
        });
    });
  }
</script>

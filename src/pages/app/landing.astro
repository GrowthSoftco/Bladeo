---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import type { Barbershop } from '@/lib/types';

const barbershop = Astro.locals.barbershop as Barbershop;

// Opening hours: default Mon–Sat 8am–7pm, Sunday closed
const defaultHours: Record<string, { open: string; close: string } | null> = {
  monday: { open: '08:00', close: '19:00' },
  tuesday: { open: '08:00', close: '19:00' },
  wednesday: { open: '08:00', close: '19:00' },
  thursday: { open: '08:00', close: '19:00' },
  friday: { open: '08:00', close: '19:00' },
  saturday: { open: '08:00', close: '19:00' },
  sunday: null,
};

const hours = (barbershop.opening_hours ?? defaultHours) as Record<string, { open: string; close: string } | null>;

const DAY_NAMES: Record<string, string> = {
  monday: 'Lunes',
  tuesday: 'Martes',
  wednesday: 'Miércoles',
  thursday: 'Jueves',
  friday: 'Viernes',
  saturday: 'Sábado',
  sunday: 'Domingo',
};
const DAY_ORDER = ['monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday', 'sunday'];
---

<DashboardLayout title="Mi Landing Pública">
  <div class="mb-8 flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-white mb-1">Mi Landing Pública</h1>
      <p class="text-[var(--color-text-secondary)]">Así te ven tus clientes en internet</p>
    </div>
    <a
      href={`/b/${barbershop.slug}`}
      target="_blank"
      class="flex items-center gap-2 px-4 py-2 bg-[#1a1a25] hover:bg-[#2a2a3a] border border-[var(--color-border)] text-white text-sm font-medium rounded-lg transition-colors whitespace-nowrap"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
        <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
      </svg>
      Ver mi página
    </a>
  </div>

  <div class="max-w-2xl space-y-6">

    <!-- Link pública -->
    <div class="bg-[var(--color-surface-elevated)] border border-[#2563eb]/30 rounded-xl p-5">
      <p class="text-xs text-[var(--color-text-secondary)] mb-1">Tu link público</p>
      <div class="flex items-center gap-2">
        <code class="flex-1 text-[#3b82f6] font-mono text-sm bg-[#1a1a25] px-3 py-2 rounded-lg border border-[var(--color-border)] truncate">
          {Astro.url.origin}/b/{barbershop.slug}
        </code>
        <button
          id="copy-link-btn"
          class="px-3 py-2 bg-[#2563eb]/20 hover:bg-[#2563eb]/30 text-[#3b82f6] text-xs font-medium rounded-lg transition-colors whitespace-nowrap"
          onclick={`navigator.clipboard.writeText('${Astro.url.origin}/b/${barbershop.slug}').then(() => { this.textContent = '¡Copiado!'; setTimeout(() => this.textContent = 'Copiar', 2000); })`}
        >
          Copiar
        </button>
      </div>
    </div>

    <!-- Perfil -->
    <div class="bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-xl p-6">
      <h2 class="font-semibold text-white mb-5">Información visible</h2>
      <form id="profile-form" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-[#f0f0f5] mb-1.5">Nombre de la barbería</label>
          <input type="text" name="name" value={barbershop.name} required class="w-full px-4 py-2.5 bg-[#1a1a25] border border-[var(--color-border)] rounded-lg text-white focus:outline-none focus:border-[#2563eb] text-sm" />
        </div>
        <div>
          <label class="block text-sm font-medium text-[#f0f0f5] mb-1.5">Descripción / Slogan</label>
          <textarea name="description" rows={2} class="w-full px-4 py-2.5 bg-[#1a1a25] border border-[var(--color-border)] rounded-lg text-white focus:outline-none focus:border-[#2563eb] text-sm resize-none">{barbershop.description ?? ''}</textarea>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-[#f0f0f5] mb-1.5">Ciudad</label>
            <input type="text" name="city" value={barbershop.city} class="w-full px-4 py-2.5 bg-[#1a1a25] border border-[var(--color-border)] rounded-lg text-white focus:outline-none focus:border-[#2563eb] text-sm" />
          </div>
          <div>
            <label class="block text-sm font-medium text-[#f0f0f5] mb-1.5">Dirección</label>
            <input type="text" name="address" value={barbershop.address ?? ''} class="w-full px-4 py-2.5 bg-[#1a1a25] border border-[var(--color-border)] rounded-lg text-white focus:outline-none focus:border-[#2563eb] text-sm" placeholder="Cra 10 #45-23" />
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-[#f0f0f5] mb-1.5">WhatsApp</label>
            <input type="tel" name="whatsapp" value={barbershop.whatsapp ?? ''} class="w-full px-4 py-2.5 bg-[#1a1a25] border border-[var(--color-border)] rounded-lg text-white focus:outline-none focus:border-[#2563eb] text-sm" placeholder="3001234567" />
          </div>
          <div>
            <label class="block text-sm font-medium text-[#f0f0f5] mb-1.5">Instagram</label>
            <input type="text" name="instagram" value={barbershop.instagram ?? ''} class="w-full px-4 py-2.5 bg-[#1a1a25] border border-[var(--color-border)] rounded-lg text-white focus:outline-none focus:border-[#2563eb] text-sm" placeholder="@mi_barberia" />
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-[#f0f0f5] mb-1.5">URL del logo</label>
          <input type="url" name="logo_url" value={barbershop.logo_url ?? ''} class="w-full px-4 py-2.5 bg-[#1a1a25] border border-[var(--color-border)] rounded-lg text-white focus:outline-none focus:border-[#2563eb] text-sm" placeholder="https://..." />
          <p class="text-xs text-[var(--color-text-secondary)] mt-1">URL directa a imagen (JPG, PNG, WebP). Ej: de Google Drive o Imgur.</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-[#f0f0f5] mb-1.5">URL imagen de portada</label>
          <input type="url" name="cover_image_url" value={barbershop.cover_image_url ?? ''} class="w-full px-4 py-2.5 bg-[#1a1a25] border border-[var(--color-border)] rounded-lg text-white focus:outline-none focus:border-[#2563eb] text-sm" placeholder="https://..." />
          <p class="text-xs text-[var(--color-text-secondary)] mt-1">Aparece como fondo difuminado en el hero de tu landing.</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-[#f0f0f5] mb-1.5">Slug (URL)</label>
          <div class="flex">
            <span class="px-3 py-2.5 bg-[#0a0a0f] border border-r-0 border-[var(--color-border)] rounded-l-lg text-[var(--color-text-secondary)] text-xs flex items-center">/b/</span>
            <input type="text" name="slug" value={barbershop.slug} required class="flex-1 px-4 py-2.5 bg-[#1a1a25] border border-[var(--color-border)] rounded-r-lg text-white focus:outline-none focus:border-[#2563eb] text-sm" />
          </div>
          <p class="text-xs text-[var(--color-text-secondary)] mt-1">Solo letras minúsculas, números y guiones. Ej: el-corte-perfecto</p>
        </div>
        <div class="flex justify-end pt-2">
          <button type="submit" class="px-5 py-2.5 bg-[#2563eb] hover:bg-[#3b82f6] text-white text-sm font-semibold rounded-lg transition-colors" id="profile-save-btn">
            Guardar cambios
          </button>
        </div>
      </form>
    </div>

    <!-- Horarios -->
    <div class="bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-xl p-6">
      <h2 class="font-semibold text-white mb-5">Horarios de atención</h2>
      <form id="hours-form" class="space-y-3">
        {DAY_ORDER.map(day => {
          const h = hours[day];
          return (
            <div class="flex items-center gap-3">
              <div class="w-24 flex-shrink-0">
                <label class="flex items-center gap-2 cursor-pointer">
                  <input
                    type="checkbox"
                    name={`${day}_open`}
                    checked={h !== null}
                    class="w-4 h-4 accent-[#2563eb]"
                    id={`toggle-${day}`}
                  />
                  <span class="text-sm font-medium text-white">{DAY_NAMES[day]}</span>
                </label>
              </div>
              <div class="flex items-center gap-2 flex-1" id={`hours-${day}`} style={h === null ? 'opacity:0.4;pointer-events:none' : ''}>
                <input
                  type="time"
                  name={`${day}_from`}
                  value={h?.open ?? '08:00'}
                  class="flex-1 px-3 py-2 bg-[#1a1a25] border border-[var(--color-border)] rounded-lg text-white text-sm focus:outline-none focus:border-[#2563eb]"
                />
                <span class="text-[var(--color-text-secondary)] text-sm">–</span>
                <input
                  type="time"
                  name={`${day}_to`}
                  value={h?.close ?? '19:00'}
                  class="flex-1 px-3 py-2 bg-[#1a1a25] border border-[var(--color-border)] rounded-lg text-white text-sm focus:outline-none focus:border-[#2563eb]"
                />
              </div>
              {h === null && <span class="text-xs text-[var(--color-text-secondary)]">Cerrado</span>}
            </div>
          );
        })}
        <div class="flex justify-end pt-2">
          <button type="submit" class="px-5 py-2.5 bg-[#2563eb] hover:bg-[#3b82f6] text-white text-sm font-semibold rounded-lg transition-colors" id="hours-save-btn">
            Guardar horarios
          </button>
        </div>
      </form>
    </div>

  </div>
</DashboardLayout>

<script define:vars={{ barbershopId: barbershop.id, dayOrder: DAY_ORDER }}>
  // Toggle day open/close
  dayOrder.forEach(day => {
    const toggle = document.getElementById(`toggle-${day}`);
    const hoursDiv = document.getElementById(`hours-${day}`);
    toggle?.addEventListener('change', () => {
      if (hoursDiv) {
        hoursDiv.style.opacity = toggle.checked ? '1' : '0.4';
        hoursDiv.style.pointerEvents = toggle.checked ? '' : 'none';
      }
    });
  });

  // Profile form
  document.getElementById('profile-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('profile-save-btn');
    const originalText = btn.textContent;
    btn.disabled = true;
    btn.textContent = 'Guardando...';

    const formData = new FormData(e.target);
    const body = Object.fromEntries(formData.entries());

    const res = await fetch(`/api/barbershops/${barbershopId}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    const data = await res.json();

    if (res.ok) {
      btn.textContent = '¡Guardado!';
      btn.style.background = '#16a34a';
      setTimeout(() => {
        btn.textContent = originalText;
        btn.style.background = '';
        btn.disabled = false;
        // Update slug in link preview if changed
        if (data.slug) {
          const origin = window.location.origin;
          document.querySelector('code').textContent = `${origin}/b/${data.slug}`;
        }
      }, 2000);
    } else {
      alert(data.error ?? 'Error al guardar');
      btn.disabled = false;
      btn.textContent = originalText;
    }
  });

  // Hours form
  document.getElementById('hours-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('hours-save-btn');
    const originalText = btn.textContent;
    btn.disabled = true;
    btn.textContent = 'Guardando...';

    const formData = new FormData(e.target);
    const opening_hours = {};

    dayOrder.forEach(day => {
      const isOpen = formData.get(`${day}_open`) === 'on';
      if (isOpen) {
        opening_hours[day] = {
          open: formData.get(`${day}_from`) || '08:00',
          close: formData.get(`${day}_to`) || '19:00',
        };
      } else {
        opening_hours[day] = null;
      }
    });

    const res = await fetch(`/api/barbershops/${barbershopId}`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ opening_hours }),
    });
    const data = await res.json();

    if (res.ok) {
      btn.textContent = '¡Guardado!';
      btn.style.background = '#16a34a';
      setTimeout(() => {
        btn.textContent = originalText;
        btn.style.background = '';
        btn.disabled = false;
      }, 2000);
    } else {
      alert(data.error ?? 'Error al guardar horarios');
      btn.disabled = false;
      btn.textContent = originalText;
    }
  });
</script>

---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { createAdminClient } from '@/lib/supabase';
import { formatCOP, formatDate } from '@/lib/utils';
import OwnerUtilities from '@/components/dashboard/OwnerUtilities';

const admin       = createAdminClient();
const barbershop  = Astro.locals.barbershop;
const member      = Astro.locals.member;
const isBarber    = member?.role === 'barber';

const today      = new Date().toISOString().split('T')[0];
const now        = new Date();
const monthStart = new Date(now.getFullYear(), now.getMonth(), 1).toISOString().split('T')[0];
const monthEnd   = today;

// ── Today queries ──────────────────────────────────────────────────────────────
const [appointmentsRes, salesTodayRes] = await Promise.all([
  admin.from('appointments')
    .select('*, services(name, price), members!barber_id(display_name)')
    .eq('barbershop_id', barbershop!.id)
    .eq('date', today)
    .neq('status', 'cancelled')
    .order('start_time'),

  isBarber
    ? admin.from('sales').select('total').eq('barbershop_id', barbershop!.id).gte('created_at', `${today}T00:00:00`)
    : admin.from('sales').select('total, barber_id, members!barber_id(id, display_name, commission_pct)').eq('barbershop_id', barbershop!.id).gte('created_at', `${today}T00:00:00`),
]);

const todayAppointments   = appointmentsRes.data   ?? [];
const todaySales          = salesTodayRes.data      ?? [];
const todayRevenue        = todaySales.reduce((s: number, r: any) => s + Number(r.total), 0);
const pendingAppointments = todayAppointments.filter(a => a.status === 'pending' || a.status === 'confirmed').length;

// Owner: build sales array for OwnerUtilities
const ownerSalesData = !isBarber
  ? (todaySales as any[]).map(s => ({
      total:          Number(s.total ?? 0),
      barber_id:      s.barber_id ?? null,
      barber_name:    s.members?.display_name ?? 'Sin asignar',
      commission_pct: s.members?.commission_pct ?? 0,
    }))
  : [];

// ── Barber: own earnings ───────────────────────────────────────────────────────
let barberEarnings = 0, barberSalesCount = 0;
if (isBarber) {
  const { data: barberSales } = await admin.from('sales').select('total')
    .eq('barbershop_id', barbershop!.id)
    .eq('barber_id', member!.id)
    .gte('created_at', `${today}T00:00:00`);
  barberSalesCount = barberSales?.length ?? 0;
  const barberRevenue = barberSales?.reduce((s, r) => s + Number(r.total), 0) ?? 0;
  barberEarnings = barberRevenue * ((member?.commission_pct ?? 0) / 100);
}

// ── Owner: monthly general stats ───────────────────────────────────────────────
let monthlyRevenue     = 0;
let monthlyExpenses    = 0;
let monthlyApptCount  = 0;
let totalClients      = 0;
let activeBarbers     = 0;
let barberPerformance: { id: string; name: string; revenue: number; apptCount: number; commission_pct: number; ownerCut: number; barberCut: number }[] = [];

if (!isBarber) {
  const [
    monthlySalesRes,
    monthlyExpensesRes,
    monthlyApptsRes,
    clientsRes,
    membersRes,
  ] = await Promise.all([
    // Monthly sales — all barbers
    admin.from('sales')
      .select('total, barber_id, members!barber_id(display_name, commission_pct)')
      .eq('barbershop_id', barbershop!.id)
      .gte('created_at', `${monthStart}T00:00:00`)
      .lte('created_at', `${monthEnd}T23:59:59`),

    // Monthly expenses
    admin.from('expenses')
      .select('amount')
      .eq('barbershop_id', barbershop!.id)
      .gte('date', monthStart)
      .lte('date', monthEnd),

    // Monthly appointments count
    admin.from('appointments')
      .select('id, barber_id', { count: 'exact' })
      .eq('barbershop_id', barbershop!.id)
      .gte('date', monthStart)
      .lte('date', monthEnd)
      .neq('status', 'cancelled'),

    // Total clients
    admin.from('clients')
      .select('id', { count: 'exact' })
      .eq('barbershop_id', barbershop!.id),

    // Active barbers
    admin.from('members')
      .select('id, display_name, commission_pct')
      .eq('barbershop_id', barbershop!.id)
      .eq('role', 'barber'),
  ]);

  const monthlySales = monthlySalesRes.data ?? [];
  monthlyRevenue     = monthlySales.reduce((s, r: any) => s + Number(r.total), 0);
  monthlyExpenses    = (monthlyExpensesRes.data ?? []).reduce((s, r: any) => s + Number(r.amount), 0);
  monthlyApptCount  = monthlyApptsRes.count ?? 0;
  totalClients      = clientsRes.count ?? 0;
  activeBarbers     = (membersRes.data ?? []).length;

  // Build per-barber performance for the month
  const barberMap: Record<string, { name: string; revenue: number; apptCount: number; commission_pct: number }> = {};
  for (const sale of monthlySales as any[]) {
    const bid  = sale.barber_id;
    if (!bid) continue;
    if (!barberMap[bid]) {
      barberMap[bid] = {
        name:           sale.members?.display_name ?? 'Desconocido',
        revenue:        0,
        apptCount:      0,
        commission_pct: Number(sale.members?.commission_pct ?? 0),
      };
    }
    barberMap[bid].revenue += Number(sale.total);
  }
  // Count appointments per barber from monthly appts
  for (const appt of (monthlyApptsRes.data ?? []) as any[]) {
    const bid = appt.barber_id;
    if (bid && barberMap[bid]) barberMap[bid].apptCount++;
  }
  barberPerformance = Object.entries(barberMap)
    .map(([id, b]) => ({
      id,
      ...b,
      barberCut: b.revenue * b.commission_pct / 100,
      ownerCut:  b.revenue * (1 - b.commission_pct / 100),
    }))
    .sort((a, b) => b.revenue - a.revenue);
}

// ── Shared ────────────────────────────────────────────────────────────────────
const { data: newClients } = await admin.from('clients')
  .select('id', { count: 'exact' })
  .eq('barbershop_id', barbershop!.id)
  .gte('created_at', (() => { const d = new Date(); d.setDate(d.getDate() - d.getDay()); return d.toISOString(); })());

const netIncome  = monthlyRevenue - monthlyExpenses;
const monthName  = now.toLocaleDateString('es-CO', { month: 'long' });

const todayFmt = now.toLocaleDateString('es-CO', {
  weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', timeZone: 'America/Bogota'
});

const statusColors: Record<string, string> = {
  pending:   'bg-warning/20 text-warning border-warning/30',
  confirmed: 'bg-brand/20 text-brand-light border-brand/30',
  completed: 'bg-success/20 text-success border-success/30',
  cancelled: 'bg-danger/20 text-danger border-danger/30',
  no_show:   'bg-[var(--color-border)] text-[var(--color-text-secondary)] border-[var(--color-border)]',
};
const statusLabels: Record<string, string> = {
  pending:   'Pendiente',
  confirmed: 'Confirmada',
  completed: 'Completada',
  cancelled: 'Cancelada',
  no_show:   'No asistió',
};

function pct(part: number, total: number) {
  if (!total) return '0%';
  return Math.round((part / total) * 100) + '%';
}
---

<DashboardLayout title="Dashboard">
  <!-- Welcome header -->
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-white mb-1">
      Buen día, {member?.display_name?.split(' ')[0]} 👋
    </h1>
    <p class="text-[var(--color-text-secondary)] capitalize">{todayFmt}</p>
  </div>

  <!-- ── HOY: stats cards ────────────────────────────────────────────────────── -->
  <p class="text-xs font-semibold uppercase tracking-widest text-[var(--color-text-secondary)] mb-3">Hoy</p>
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-xl p-5">
      <p class="text-[var(--color-text-secondary)] text-xs font-medium uppercase tracking-wide mb-3">Citas hoy</p>
      <p class="text-3xl font-bold text-white">{todayAppointments.length}</p>
      <p class="text-[var(--color-text-secondary)] text-xs mt-1">{pendingAppointments} pendientes</p>
    </div>

    {isBarber ? (
      <div class="bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-xl p-5">
        <p class="text-[var(--color-text-secondary)] text-xs font-medium uppercase tracking-wide mb-3">Mis ganancias hoy</p>
        <p class="text-3xl font-bold text-[var(--color-success)]">{formatCOP(barberEarnings)}</p>
        <p class="text-[var(--color-text-secondary)] text-xs mt-1">{barberSalesCount} ventas · {member?.commission_pct ?? 0}%</p>
      </div>
    ) : (
      <div class="bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-xl p-5">
        <p class="text-[var(--color-text-secondary)] text-xs font-medium uppercase tracking-wide mb-3">Ingresos hoy</p>
        <p class="text-3xl font-bold text-white">{formatCOP(todayRevenue)}</p>
        <p class="text-[var(--color-text-secondary)] text-xs mt-1">{todaySales.length} ventas</p>
      </div>
    )}

    <div class="bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-xl p-5">
      <p class="text-[var(--color-text-secondary)] text-xs font-medium uppercase tracking-wide mb-3">Clientes nuevos</p>
      <p class="text-3xl font-bold text-white">{newClients?.length ?? 0}</p>
      <p class="text-[var(--color-text-secondary)] text-xs mt-1">Esta semana</p>
    </div>

    <div class="bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-xl p-5">
      <p class="text-[var(--color-text-secondary)] text-xs font-medium uppercase tracking-wide mb-3">Citas pendientes</p>
      <p class="text-3xl font-bold text-white">{pendingAppointments}</p>
      <p class="text-[var(--color-text-secondary)] text-xs mt-1">Para hoy</p>
    </div>
  </div>

  <!-- Owner utilities today -->
  {!isBarber && (
    <div class="mb-8">
      <OwnerUtilities sales={ownerSalesData} client:load />
    </div>
  )}

  <!-- ── MES: resumen mensual (solo admin) ───────────────────────────────────── -->
  {!isBarber && (
    <>
      <p class="text-xs font-semibold uppercase tracking-widest text-[var(--color-text-secondary)] mb-3 capitalize">
        {monthName} — resumen general
      </p>

      <!-- 4 big monthly stat cards -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <!-- Ingresos del mes -->
        <div class="bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-xl p-5">
          <p class="text-[var(--color-text-secondary)] text-xs font-medium uppercase tracking-wide mb-3">Ingresos del mes</p>
          <p class="text-2xl font-bold text-white">{formatCOP(monthlyRevenue)}</p>
          <p class="text-[var(--color-text-secondary)] text-xs mt-1">{monthlyApptCount} citas</p>
        </div>

        <!-- Gastos del mes -->
        <div class="bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-xl p-5">
          <p class="text-[var(--color-text-secondary)] text-xs font-medium uppercase tracking-wide mb-3">Gastos del mes</p>
          <p class="text-2xl font-bold text-red-400">{formatCOP(monthlyExpenses)}</p>
          <p class="text-[var(--color-text-secondary)] text-xs mt-1">{pct(monthlyExpenses, monthlyRevenue)} de ingresos</p>
        </div>

        <!-- Ganancia neta -->
        <div class={`bg-[var(--color-surface-elevated)] border rounded-xl p-5 ${netIncome >= 0 ? 'border-emerald-500/30' : 'border-red-500/30'}`}>
          <p class="text-[var(--color-text-secondary)] text-xs font-medium uppercase tracking-wide mb-3">Ganancia neta</p>
          <p class={`text-2xl font-bold ${netIncome >= 0 ? 'text-emerald-400' : 'text-red-400'}`}>{formatCOP(netIncome)}</p>
          <p class="text-[var(--color-text-secondary)] text-xs mt-1">Ingresos − gastos</p>
        </div>

        <!-- Clientes totales + barberos -->
        <div class="bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-xl p-5">
          <p class="text-[var(--color-text-secondary)] text-xs font-medium uppercase tracking-wide mb-3">Clientes totales</p>
          <p class="text-2xl font-bold text-white">{totalClients}</p>
          <p class="text-[var(--color-text-secondary)] text-xs mt-1">{activeBarbers} barbero{activeBarbers !== 1 ? 's' : ''} activo{activeBarbers !== 1 ? 's' : ''}</p>
        </div>
      </div>

      <!-- Rendimiento por barbero (mes actual) -->
      {barberPerformance.length > 0 && (
        <div class="bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-xl mb-8">
          <div class="flex items-center justify-between px-6 py-4 border-b border-[var(--color-border)]">
            <h2 class="font-semibold text-white text-sm">Rendimiento por barbero — {monthName}</h2>
            <a href="/app/accounting" class="text-xs text-[var(--color-brand-light)] hover:underline">
              Ver contabilidad completa →
            </a>
          </div>

          {/* Desktop table */}
          <div class="hidden sm:block overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-[var(--color-border)]">
                  <th class="text-left px-6 py-3 text-xs font-semibold uppercase tracking-wide text-[var(--color-text-secondary)]">Barbero</th>
                  <th class="text-right px-4 py-3 text-xs font-semibold uppercase tracking-wide text-[var(--color-text-secondary)]">Citas</th>
                  <th class="text-right px-4 py-3 text-xs font-semibold uppercase tracking-wide text-[var(--color-text-secondary)]">Ventas</th>
                  <th class="text-right px-4 py-3 text-xs font-semibold uppercase tracking-wide text-[var(--color-text-secondary)]">Comisión</th>
                  <th class="text-right px-4 py-3 text-xs font-semibold uppercase tracking-wide text-[var(--color-text-secondary)]">Tu parte</th>
                  <th class="text-right px-6 py-3 text-xs font-semibold uppercase tracking-wide text-[var(--color-text-secondary)]">A pagar</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-[var(--color-border)]">
                {barberPerformance.map((b, i) => (
                  <tr class="hover:bg-[var(--color-surface-overlay)] transition-colors">
                    <td class="px-6 py-4">
                      <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-full bg-[var(--color-brand)]/20 flex items-center justify-center text-xs font-bold text-[var(--color-brand-light)] flex-shrink-0">
                          {b.name.charAt(0).toUpperCase()}
                        </div>
                        <div>
                          <p class="font-medium text-white">{b.name}</p>
                          <p class="text-xs text-[var(--color-text-secondary)]">{b.commission_pct}% comisión</p>
                        </div>
                      </div>
                    </td>
                    <td class="px-4 py-4 text-right text-[var(--color-text-primary)]">{b.apptCount}</td>
                    <td class="px-4 py-4 text-right font-semibold text-white">{formatCOP(b.revenue)}</td>
                    <td class="px-4 py-4 text-right text-[var(--color-text-secondary)]">{b.commission_pct}%</td>
                    <td class="px-4 py-4 text-right text-[var(--color-brand-light)]">{formatCOP(b.ownerCut)}</td>
                    <td class="px-6 py-4 text-right">
                      <span class="font-semibold text-emerald-400">{formatCOP(b.barberCut)}</span>
                    </td>
                  </tr>
                ))}
                {/* Totals row */}
                <tr class="bg-[var(--color-surface-overlay)]">
                  <td class="px-6 py-3 text-xs font-bold text-[var(--color-text-secondary)] uppercase">Total</td>
                  <td class="px-4 py-3 text-right font-bold text-white">{barberPerformance.reduce((s, b) => s + b.apptCount, 0)}</td>
                  <td class="px-4 py-3 text-right font-bold text-white">{formatCOP(barberPerformance.reduce((s, b) => s + b.revenue, 0))}</td>
                  <td class="px-4 py-3"></td>
                  <td class="px-4 py-3 text-right font-bold text-[var(--color-brand-light)]">{formatCOP(barberPerformance.reduce((s, b) => s + b.ownerCut, 0))}</td>
                  <td class="px-6 py-3 text-right font-bold text-emerald-400">{formatCOP(barberPerformance.reduce((s, b) => s + b.barberCut, 0))}</td>
                </tr>
              </tbody>
            </table>
          </div>

          {/* Mobile cards */}
          <div class="sm:hidden divide-y divide-[var(--color-border)]">
            {barberPerformance.map(b => (
              <div class="px-4 py-4">
                <div class="flex items-center justify-between mb-2">
                  <div class="flex items-center gap-2">
                    <div class="w-7 h-7 rounded-full bg-[var(--color-brand)]/20 flex items-center justify-center text-xs font-bold text-[var(--color-brand-light)]">
                      {b.name.charAt(0).toUpperCase()}
                    </div>
                    <span class="font-medium text-white text-sm">{b.name}</span>
                  </div>
                  <span class="text-white font-semibold text-sm">{formatCOP(b.revenue)}</span>
                </div>
                <div class="grid grid-cols-3 gap-2 text-xs">
                  <div>
                    <p class="text-[var(--color-text-secondary)]">Citas</p>
                    <p class="text-white font-medium">{b.apptCount}</p>
                  </div>
                  <div>
                    <p class="text-[var(--color-text-secondary)]">Tu parte</p>
                    <p class="text-[var(--color-brand-light)] font-medium">{formatCOP(b.ownerCut)}</p>
                  </div>
                  <div>
                    <p class="text-[var(--color-text-secondary)]">A pagar</p>
                    <p class="text-emerald-400 font-medium">{formatCOP(b.barberCut)}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}
    </>
  )}

  <!-- ── Citas de hoy + acciones rápidas ─────────────────────────────────────── -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-xl">
      <div class="flex items-center justify-between px-6 py-4 border-b border-[var(--color-border)]">
        <h2 class="font-semibold text-white">Citas de hoy</h2>
        <a href="/app/agenda" class="text-sm text-[var(--color-brand-light)] hover:underline transition-colors">Ver agenda →</a>
      </div>
      <div class="divide-y divide-[var(--color-border)]">
        {todayAppointments.length === 0 ? (
          <div class="flex flex-col items-center justify-center py-12 text-center">
            <svg class="w-10 h-10 text-[#2a2a3a] mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
            <p class="text-[var(--color-text-secondary)] text-sm">No hay citas agendadas para hoy.</p>
            <a href="/app/agenda" class="mt-3 text-sm text-[var(--color-brand-light)] hover:underline">+ Nueva cita</a>
          </div>
        ) : (
          todayAppointments.map(apt => (
            <div class="flex items-center gap-4 px-6 py-4">
              <div class="text-center w-14 flex-shrink-0">
                <p class="text-sm font-semibold text-white">{apt.start_time?.slice(0, 5)}</p>
                <p class="text-xs text-[var(--color-text-secondary)]">{apt.end_time?.slice(0, 5)}</p>
              </div>
              <div class="flex-1 min-w-0">
                <p class="font-medium text-white truncate">{apt.client_name}</p>
                <p class="text-sm text-[var(--color-text-secondary)] truncate">
                  {(apt as any).services?.name} · {(apt as any).members?.display_name}
                </p>
              </div>
              <span class={`text-xs font-medium px-2.5 py-1 rounded-full border ${statusColors[apt.status]}`}>
                {statusLabels[apt.status]}
              </span>
            </div>
          ))
        )}
      </div>
    </div>

    <!-- Acciones rápidas + info barbería -->
    <div class="space-y-4">
      <div class="bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-xl p-5">
        <h2 class="font-semibold text-white mb-4">Acciones rápidas</h2>
        <div class="space-y-2">
          <a href="/app/agenda" class="flex items-center gap-3 px-4 py-3 bg-[var(--color-brand)] hover:opacity-90 rounded-lg text-white text-sm font-medium transition-opacity">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            Nueva cita
          </a>
          <a href="/app/pos" class="flex items-center gap-3 px-4 py-3 bg-[var(--color-surface-overlay)] border border-[var(--color-border)] rounded-lg text-white text-sm font-medium hover:bg-[var(--color-surface-elevated)] transition-colors">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle>
              <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
            </svg>
            Registrar venta
          </a>
          <a href="/app/clients" class="flex items-center gap-3 px-4 py-3 bg-[var(--color-surface-overlay)] border border-[var(--color-border)] rounded-lg text-white text-sm font-medium hover:bg-[var(--color-surface-elevated)] transition-colors">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle>
            </svg>
            Agregar cliente
          </a>
          {!isBarber && (
            <a href="/app/accounting" class="flex items-center gap-3 px-4 py-3 bg-[var(--color-surface-overlay)] border border-[var(--color-border)] rounded-lg text-white text-sm font-medium hover:bg-[var(--color-surface-elevated)] transition-colors">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line>
              </svg>
              Ver contabilidad
            </a>
          )}
        </div>
      </div>

      <!-- Barbershop info -->
      <div class="bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-xl p-5">
        <h2 class="font-semibold text-white mb-3">Tu barbería</h2>
        <div class="space-y-2 text-sm">
          <div class="flex items-center gap-2 text-[var(--color-text-secondary)]">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle>
            </svg>
            <span>{barbershop?.city ?? 'Sin configurar'}</span>
          </div>
          {barbershop?.phone && (
            <div class="flex items-center gap-2 text-[var(--color-text-secondary)]">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.36 12 19.79 19.79 0 0 1 1.21 3.18 2 2 0 0 1 3.22 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16h0z"></path>
              </svg>
              <span>{barbershop.phone}</span>
            </div>
          )}
          <div class="pt-2 border-t border-[var(--color-border)]">
            <a href={`/b/${barbershop?.slug}`} target="_blank" class="text-[var(--color-brand-light)] hover:underline text-xs">
              Ver perfil público →
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</DashboardLayout>

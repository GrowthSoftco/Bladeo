---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import BankingTerminal from '@/components/banking/BankingTerminal';
const barbershop = Astro.locals.barbershop;
const bankingEnabled = barbershop?.is_banking_correspondent === true;
const bankingEntity = (barbershop?.payment_details as any)?._banking_entity ?? null;
const barbershopId = barbershop?.id ?? '';
---
<DashboardLayout title="Corresponsal Bancario">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-white mb-1">Corresponsal Bancario</h1>
    <p class="text-[var(--color-text-secondary)]">Registro de transacciones y cuadre de comisiones</p>
  </div>

  <!-- Not activated -->
  <div id="banking-disabled-msg" class={!bankingEnabled ? '' : 'hidden'}>
    <div class="bg-[var(--color-surface-elevated)] border border-amber-500/30 rounded-xl p-10 text-center max-w-lg mx-auto">
      <div class="text-5xl mb-4">🏦</div>
      <h3 class="text-lg font-semibold text-white mb-2">Módulo no activado</h3>
      <p class="text-[var(--color-text-secondary)] text-sm mb-6">
        El módulo de corresponsal bancario no está habilitado para esta barbería.
        Actívalo en Configuración para empezar a registrar transacciones.
      </p>
      <a href="/app/settings" class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#2563eb] hover:bg-[#3b82f6] text-white font-semibold text-sm rounded-lg transition-colors">
        Ir a Configuración →
      </a>
    </div>
  </div>

  <!-- Terminal -->
  <div class={bankingEnabled ? '' : 'hidden'}>
    <BankingTerminal entity={bankingEntity} barbershopId={barbershopId} client:load />
  </div>
</DashboardLayout>

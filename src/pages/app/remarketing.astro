                    </span>
                    <span class="text-xs text-[var(--color-text-secondary)]">Después de {rule.days_after_last_visit} días sin visita</span>
                    {tpl.media_url && (
                      <span class="inline-flex items-center gap-1 text-[10px] text-[var(--color-text-secondary)] bg-[#1a1a25] px-2 py-0.5 rounded-full">
                        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                        Imagen
                      </span>
                    )}
                  </div>
                  <h3 class="font-semibold text-white mb-1">{rule.name}</h3>
                  <p class="text-sm text-[var(--color-text-secondary)] line-clamp-2">{tpl.text}</p>
                  {tpl.media_url && (
                    <img src={tpl.media_url} alt="Media" class="mt-2 w-20 h-14 object-cover rounded-lg border border-[var(--color-border)]" />
                  )}
                </div>
                <div class="flex items-center gap-2 flex-shrink-0">
                  <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" class="sr-only peer rule-toggle" checked={rule.is_active} data-id={rule.id} />
                    <div class="w-9 h-5 bg-[#2a2a3a] rounded-full peer peer-checked:after:translate-x-full peer-checked:bg-[#2563eb] after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all"></div>
                  </label>
                  <button class="rule-edit-btn p-1.5 text-[var(--color-text-secondary)] hover:text-white transition-colors" data-id={rule.id}
                    data-rule={JSON.stringify({ ...rule, ...tpl })}>
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                  </button>
                  <button class="rule-delete-btn p-1.5 text-[var(--color-text-secondary)] hover:text-red-400 transition-colors" data-id={rule.id}>
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                  </button>
                </div>
              </div>
            </div>
          );
        })}
      </div>

      <!-- Activity + tip -->
      <div class="lg:col-span-2 space-y-4">
        <div class="bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-xl overflow-hidden">
          <div class="px-5 py-3.5 border-b border-[var(--color-border)]">
            <h2 class="font-semibold text-white text-sm">Actividad reciente</h2>
          </div>
          {recentLogs.length === 0 ? (
            <div class="p-8 text-center"><p class="text-[var(--color-text-secondary)] text-sm">Sin actividad registrada</p></div>
          ) : (
            <div class="divide-y divide-[#2a2a3a] max-h-[420px] overflow-y-auto">
              {recentLogs.map((log: any) => (
                <div class="px-4 py-3">
                  <div class="flex items-center justify-between gap-2 mb-0.5">
                    <span class="text-sm font-medium text-white truncate">{(log as any).clients?.name ?? 'Cliente'}</span>
                    <span class={`text-[10px] font-semibold px-2 py-0.5 rounded-full flex-shrink-0 ${
                      (log as any).status === 'sent' ? 'bg-green-500/20 text-green-400' :
                      (log as any).status === 'pending' ? 'bg-amber-500/20 text-amber-400' :
                      'bg-red-500/20 text-red-400'
                    }`}>
                      {(log as any).status === 'sent' ? 'Enviado' : (log as any).status === 'pending' ? 'Pendiente' : 'Fallido'}
                    </span>
                  </div>
                  <p class="text-xs text-[var(--color-text-secondary)]">{(log as any).remarketing_rules?.name ?? '—'}</p>
                  <p class="text-[11px] text-[#555568] mt-0.5">
                    {new Date((log as any).scheduled_date ?? (log as any).created_at).toLocaleDateString('es-CO', { day: '2-digit', month: 'short', year: 'numeric' })}
                  </p>
                </div>
              ))}
            </div>
          )}
        </div>

        <div class="bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-xl p-4">
          <p class="text-xs font-semibold text-white mb-2">Variables disponibles</p>
          <div class="flex flex-wrap gap-1.5">
            {['{nombre}', '{dias}', '{barberia}', '{telefono}'].map(v => (
              <span class="text-xs font-mono px-2 py-1 bg-[#1a1a25] border border-[var(--color-border)] rounded text-[var(--color-text-secondary)]">{v}</span>
            ))}
          </div>
          <p class="text-[11px] text-[#555568] mt-2">Escríbelas en el mensaje y se reemplazarán automáticamente al enviar.</p>
        </div>
      </div>
    </div>
  </>
)}

</DashboardLayout>


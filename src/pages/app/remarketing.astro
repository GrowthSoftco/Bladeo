          class="w-full px-4 py-2.5 bg-[#1a1a25] border border-[var(--color-border)] rounded-lg text-white text-sm font-mono focus:outline-none focus:border-[#2563eb] transition-colors"
          placeholder="+15005550006" />
      </div>

      <p id="twilio-error" class="text-red-400 text-sm hidden"></p>

      <button id="btn-save-twilio"
        class="w-full py-3 bg-[#25D366] hover:bg-[#1ebe5d] text-white font-semibold rounded-lg text-sm transition-colors">
        Guardar y activar Re-Marketing

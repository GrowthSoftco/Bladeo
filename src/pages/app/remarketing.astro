<!-- ═══════════════ RULE MODAL ═══════════════════════════════════════════════ -->
<div id="rule-modal" class="fixed inset-0 z-50 hidden">
  <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" id="rule-modal-backdrop"></div>
  <div class="absolute inset-0 flex items-center justify-center p-4">
    <div class="bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-2xl w-full max-w-lg shadow-2xl max-h-[90vh] overflow-y-auto">
      <div class="flex items-center justify-between px-6 py-4 border-b border-[var(--color-border)] sticky top-0 bg-[var(--color-surface-elevated)] z-10">
        <h2 class="font-semibold text-white" id="modal-title">Nueva Regla</h2>
        <button id="rule-modal-close" class="text-[var(--color-text-secondary)] hover:text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <div class="p-6 space-y-5">
        <input type="hidden" id="rule-edit-id" value="" />

        <!-- Name -->
        <div>
          <label class="block text-sm font-medium text-[#f0f0f5] mb-1.5">Nombre de la regla *</label>
          <input type="text" id="rule-name" placeholder="Ej: Clientes 30 días inactivos"
            class="w-full px-4 py-2.5 bg-[#1a1a25] border border-[var(--color-border)] rounded-lg text-white text-sm focus:outline-none focus:border-[#2563eb]" />
        </div>

        <!-- Days -->
        <div>
          <label class="block text-sm font-medium text-[#f0f0f5] mb-1.5">Días sin visita para activar *</label>
          <div class="flex items-center gap-3 mb-2">
            <input type="number" id="rule-days" min="1" max="365" value="30"
              class="w-24 px-4 py-2.5 bg-[#1a1a25] border border-[var(--color-border)] rounded-lg text-white text-sm focus:outline-none focus:border-[#2563eb]" />
            <span class="text-sm text-[var(--color-text-secondary)]">días sin visita</span>
          </div>
          <div class="flex gap-2">
            {[15, 30, 45, 60, 90].map(d => (
              <button class="days-preset px-2.5 py-1 text-xs bg-[#1a1a25] border border-[var(--color-border)] rounded-lg text-[var(--color-text-secondary)] hover:text-white hover:border-[#3a3a4a] transition-colors" data-days={String(d)}>{d}d</button>
            ))}
          </div>
        </div>

        <!-- Message -->
        <div>
          <label class="block text-sm font-medium text-[#f0f0f5] mb-1.5">Mensaje *</label>
          <textarea id="rule-message" rows={5}
            placeholder="Hola {nombre}, hace {dias} días que no te vemos en {barberia}. ¡Te esperamos! 💈"
            class="w-full px-4 py-2.5 bg-[#1a1a25] border border-[var(--color-border)] rounded-lg text-white text-sm focus:outline-none focus:border-[#2563eb] resize-none"></textarea>
          <!-- Variable chips -->
          <div class="flex flex-wrap gap-1.5 mt-2">
            {['{nombre}', '{dias}', '{barberia}', '{telefono}'].map(v => (
              <button class="var-chip text-xs font-mono px-2 py-1 bg-[#1a1a25] border border-[var(--color-border)] rounded text-[var(--color-text-secondary)] hover:text-white hover:border-[#2563eb] transition-colors" data-var={v}>{v}</button>
            ))}
          </div>
        </div>

        <!-- Media -->
        <div>
          <label class="block text-sm font-medium text-[#f0f0f5] mb-1.5">Imagen o archivo <span class="text-[var(--color-text-secondary)] text-xs">(opcional)</span></label>

          <!-- Upload zone -->
          <div id="upload-zone"
            class="border-2 border-dashed border-[var(--color-border)] rounded-xl p-6 text-center cursor-pointer hover:border-[#2563eb]/50 transition-colors"
            ondragover="event.preventDefault()"
            ondrop="handleFileDrop(event)">
            <input type="file" id="media-file-input" accept="image/*" class="hidden" />
            <div id="upload-placeholder">
              <svg class="mx-auto mb-2 text-[#555568]" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
              <p class="text-sm text-[var(--color-text-secondary)]">Arrastra una imagen o <button type="button" id="btn-browse" class="text-[#2563eb] hover:underline">selecciona un archivo</button></p>
              <p class="text-xs text-[#555568] mt-1">JPG, PNG, WEBP, GIF · Máx 5MB</p>
            </div>
            <div id="upload-preview" class="hidden">
              <img id="preview-img" src="" alt="preview" class="mx-auto max-h-32 rounded-lg object-contain mb-2" />
              <button type="button" id="btn-remove-media" class="text-xs text-red-400 hover:text-red-300 transition-colors">✕ Eliminar imagen</button>
            </div>
            <div id="upload-progress" class="hidden">
              <div class="flex items-center justify-center gap-2 text-sm text-[var(--color-text-secondary)]">
                <svg class="animate-spin" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
                Subiendo...
              </div>
            </div>
          </div>

          <!-- Or URL -->
          <div class="flex items-center gap-3 my-3">
            <div class="flex-1 h-px bg-[#2a2a3a]"></div>
            <span class="text-xs text-[#555568]">o pega una URL</span>
            <div class="flex-1 h-px bg-[#2a2a3a]"></div>
          </div>
          <input type="url" id="rule-media-url"
            placeholder="https://ejemplo.com/imagen.jpg"
            class="w-full px-4 py-2.5 bg-[#1a1a25] border border-[var(--color-border)] rounded-lg text-white text-sm font-mono focus:outline-none focus:border-[#2563eb]" />
        </div>

        <p id="rule-modal-error" class="text-red-400 text-sm hidden"></p>

        <div class="flex gap-3 pt-1">
          <button id="rule-modal-cancel" class="flex-1 py-2.5 border border-[var(--color-border)] text-[var(--color-text-secondary)] hover:text-white rounded-lg text-sm transition-colors">Cancelar</button>
          <button id="rule-modal-save" class="flex-1 py-2.5 bg-[#2563eb] hover:bg-[#3b82f6] text-white font-semibold rounded-lg text-sm transition-colors">Guardar regla</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ barbershopId, rulesJson }}>
  var _uploadedMediaUrl = null;

  // ── Twilio setup ───────────────────────────────────────────────────────────
  var saveTwilioBtn = document.getElementById('btn-save-twilio');
  if (saveTwilioBtn) {
    saveTwilioBtn.addEventListener('click', function() {
      var sid = document.getElementById('twilio-sid').value.trim();
      var token = document.getElementById('twilio-token').value.trim();
      var from = document.getElementById('twilio-from').value.trim();
      var smsFrom = document.getElementById('twilio-sms-from')?.value.trim() || '';
      var errEl = document.getElementById('twilio-error');

      if (!sid || !token || !from) {
        errEl.textContent = 'Completa todos los campos.';
        errEl.classList.remove('hidden');
        return;
      }
      if (!from.startsWith('whatsapp:')) {
        errEl.textContent = 'El número debe empezar con "whatsapp:" (ej: whatsapp:+15005550006)';
        errEl.classList.remove('hidden');
        return;
      }
      errEl.classList.add('hidden');
      saveTwilioBtn.disabled = true;
      saveTwilioBtn.textContent = 'Guardando...';

      fetch('/api/remarketing/twilio-config', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ account_sid: sid, auth_token: token, whatsapp_from: from, sms_from: smsFrom }),
      })
        .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, d: d }; }); })
        .then(function(result) {
          if (result.ok) {
            window.location.reload();
          } else {
            errEl.textContent = result.d.error || 'Error al guardar.';
            errEl.classList.remove('hidden');
            saveTwilioBtn.disabled = false;
            saveTwilioBtn.textContent = 'Guardar y activar Re-Marketing';
          }
        })
        .catch(function() {
          errEl.textContent = 'Error de conexión.';
          errEl.classList.remove('hidden');
          saveTwilioBtn.disabled = false;
          saveTwilioBtn.textContent = 'Guardar y activar Re-Marketing';
        });
    });
  }

  // Reconfigurar button
  var reconfigBtn = document.getElementById('btn-reconfig');
  if (reconfigBtn) {
    reconfigBtn.addEventListener('click', function() {
      if (!confirm('¿Deseas eliminar la configuración de Twilio actual?')) return;
      fetch('/api/remarketing/twilio-config', { method: 'DELETE' })
        .then(function(r) { if (r.ok) window.location.reload(); });
    });
  }

  // ── Modal helpers ──────────────────────────────────────────────────────────
  function openModal(rule) {
    _uploadedMediaUrl = null;
    var modal = document.getElementById('rule-modal');
    document.getElementById('modal-title').textContent = rule ? 'Editar Regla' : 'Nueva Regla';
    document.getElementById('rule-name').value = rule ? rule.name : '';
    document.getElementById('rule-days').value = rule ? String(rule.days_after_last_visit) : '30';
    document.getElementById('rule-message').value = rule ? (rule.text || rule.message_template || '') : '';
    document.getElementById('rule-edit-id').value = rule ? rule.id : '';
    document.getElementById('rule-modal-error').classList.add('hidden');

    var mediaUrl = rule ? (rule.media_url || '') : '';
    document.getElementById('rule-media-url').value = mediaUrl;
    showPreviewUrl(mediaUrl);

    modal.classList.remove('hidden');
    document.getElementById('rule-name').focus();
  }

  function closeModal() {
    document.getElementById('rule-modal').classList.add('hidden');
    _uploadedMediaUrl = null;
    resetUploadZone();
  }

  function showPreviewUrl(url) {
    var placeholder = document.getElementById('upload-placeholder');
    var preview = document.getElementById('upload-preview');
    var previewImg = document.getElementById('preview-img');
    if (url) {
      previewImg.src = url;
      placeholder.classList.add('hidden');
      preview.classList.remove('hidden');
      _uploadedMediaUrl = url;
    } else {
      placeholder.classList.remove('hidden');
      preview.classList.add('hidden');
      _uploadedMediaUrl = null;
    }
  }

  function resetUploadZone() {
    document.getElementById('upload-placeholder').classList.remove('hidden');
    document.getElementById('upload-preview').classList.add('hidden');
    document.getElementById('upload-progress').classList.add('hidden');
    document.getElementById('preview-img').src = '';
    document.getElementById('rule-media-url').value = '';
    document.getElementById('media-file-input').value = '';
    _uploadedMediaUrl = null;
  }

  // ── File upload ────────────────────────────────────────────────────────────
  function uploadFile(file) {
    if (!file) return;
    document.getElementById('upload-placeholder').classList.add('hidden');
    document.getElementById('upload-preview').classList.add('hidden');
    document.getElementById('upload-progress').classList.remove('hidden');

    var fd = new FormData();
    fd.append('file', file);
    fetch('/api/remarketing/upload', { method: 'POST', body: fd })
      .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, d: d }; }); })
      .then(function(result) {
        document.getElementById('upload-progress').classList.add('hidden');
        if (result.ok) {
          _uploadedMediaUrl = result.d.url;
          document.getElementById('rule-media-url').value = result.d.url;
          showPreviewUrl(result.d.url);
        } else {
          document.getElementById('upload-placeholder').classList.remove('hidden');
          document.getElementById('rule-modal-error').textContent = result.d.error || 'Error al subir imagen.';
          document.getElementById('rule-modal-error').classList.remove('hidden');
        }
      })
      .catch(function() {
        document.getElementById('upload-progress').classList.add('hidden');
        document.getElementById('upload-placeholder').classList.remove('hidden');
        document.getElementById('rule-modal-error').textContent = 'Error de conexión al subir imagen.';
        document.getElementById('rule-modal-error').classList.remove('hidden');
      });
  }

  window.handleFileDrop = function(e) {
    e.preventDefault();
    var file = e.dataTransfer?.files?.[0];
    if (file) uploadFile(file);
  };

  var browseBtn = document.getElementById('btn-browse');
  var fileInput = document.getElementById('media-file-input');
  if (browseBtn && fileInput) {
    browseBtn.addEventListener('click', function() { fileInput.click(); });
    fileInput.addEventListener('change', function() {
      if (fileInput.files[0]) uploadFile(fileInput.files[0]);
    });
  }

  var removeMediaBtn = document.getElementById('btn-remove-media');
  if (removeMediaBtn) {
    removeMediaBtn.addEventListener('click', function() { resetUploadZone(); });
  }

  // Sync URL input → preview
  var mediaUrlInput = document.getElementById('rule-media-url');
  if (mediaUrlInput) {
    mediaUrlInput.addEventListener('blur', function() {
      var url = mediaUrlInput.value.trim();
      if (url) showPreviewUrl(url);
      else resetUploadZone();
    });
  }

  // ── Save rule ──────────────────────────────────────────────────────────────
  function getMediaUrl() {
    return _uploadedMediaUrl || document.getElementById('rule-media-url')?.value.trim() || null;
  }

  // ── Rule card builder ──────────────────────────────────────────────────────
  function buildRuleCard(rule) {
    var tplText = rule.text || (function() { try { return JSON.parse(rule.message_template).text; } catch(e) { return rule.message_template; } })();
    var tplMedia = rule.media_url || (function() { try { return JSON.parse(rule.message_template).media_url; } catch(e) { return null; } })();
    var statusClass = rule.is_active ? 'bg-green-500/20 text-green-400' : 'bg-[#2a2a3a] text-[var(--color-text-secondary)]';
    var statusLabel = rule.is_active ? '● Activa' : '○ Pausada';
    var mediaBadge = tplMedia ? '<span class="inline-flex items-center gap-1 text-[10px] text-[var(--color-text-secondary)] bg-[#1a1a25] px-2 py-0.5 rounded-full"><svg xmlns=\'http://www.w3.org/2000/svg\' width=\'10\' height=\'10\' viewBox=\'0 0 24 24\' fill=\'none\' stroke=\'currentColor\' stroke-width=\'2\'><rect x=\'3\' y=\'3\' width=\'18\' height=\'18\' rx=\'2\'/><circle cx=\'8.5\' cy=\'8.5\' r=\'1.5\'/><polyline points=\'21 15 16 10 5 21\'/></svg>Imagen</span>' : '';
    var mediaThumb = tplMedia ? '<img src="' + tplMedia + '" alt="Media" class="mt-2 w-20 h-14 object-cover rounded-lg border border-[var(--color-border)]" />' : '';
    var ruleJson = JSON.stringify({ ...rule, text: tplText, media_url: tplMedia }).replace(/"/g, '&quot;');

    var div = document.createElement('div');
    div.className = 'rule-card bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-xl p-5';
    div.dataset.id = rule.id;
    div.innerHTML =
      '<div class="flex items-start justify-between gap-3">'
      + '<div class="flex-1 min-w-0">'
      + '<div class="flex items-center gap-2 mb-1.5">'
      + '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold rule-status-badge ' + statusClass + '">' + statusLabel + '</span>'
      + '<span class="text-xs text-[var(--color-text-secondary)]">Después de ' + rule.days_after_last_visit + ' días sin visita</span>'
      + mediaBadge
      + '</div>'
      + '<h3 class="font-semibold text-white mb-1">' + rule.name + '</h3>'
      + '<p class="text-sm text-[var(--color-text-secondary)] line-clamp-2">' + tplText + '</p>'
      + mediaThumb
      + '</div>'
      + '<div class="flex items-center gap-2 flex-shrink-0">'
      + '<label class="relative inline-flex items-center cursor-pointer">'
      + '<input type="checkbox" class="sr-only peer rule-toggle" ' + (rule.is_active ? 'checked' : '') + ' data-id="' + rule.id + '" />'
      + '<div class="w-9 h-5 bg-[#2a2a3a] rounded-full peer peer-checked:after:translate-x-full peer-checked:bg-[#2563eb] after:content-[\'\'] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all"></div>'
      + '</label>'
      + '<button class="rule-edit-btn p-1.5 text-[var(--color-text-secondary)] hover:text-white transition-colors" data-id="' + rule.id + '" data-rule="' + ruleJson + '">'
      + '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>'
      + '</button>'
      + '<button class="rule-delete-btn p-1.5 text-[var(--color-text-secondary)] hover:text-red-400 transition-colors" data-id="' + rule.id + '">'
      + '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>'
      + '</button>'
      + '</div></div>';
    return div;
  }

  // ── Delegated events ───────────────────────────────────────────────────────
  document.addEventListener('click', function(e) {
    var t = e.target;

    if (t.closest('#btn-new-rule')) { openModal(null); return; }
    if (t.closest('#rule-modal-close') || t.closest('#rule-modal-cancel') || t.id === 'rule-modal-backdrop') { closeModal(); return; }

    var editBtn = t.closest('.rule-edit-btn');
    if (editBtn) {
      try { openModal(JSON.parse(editBtn.dataset.rule.replace(/&quot;/g, '"'))); } catch(e) {}
      return;
    }

    var deleteBtn = t.closest('.rule-delete-btn');
    if (deleteBtn) {
      if (!confirm('¿Eliminar esta regla?')) return;
      fetch('/api/remarketing/rules/' + deleteBtn.dataset.id, { method: 'DELETE' })
        .then(function(r) {
          if (r.ok || r.status === 204) {
            var card = document.querySelector('.rule-card[data-id="' + deleteBtn.dataset.id + '"]');
            if (card) card.remove();
            var list = document.getElementById('rules-list');
            if (list && !list.querySelector('.rule-card')) {
              var empty = document.createElement('div');
              empty.id = 'rules-empty';
              empty.className = 'bg-[var(--color-surface-elevated)] border border-dashed border-[var(--color-border)] rounded-xl p-12 text-center';
              empty.innerHTML = '<div class="text-4xl mb-3">📢</div><p class="text-white font-semibold mb-1">Sin reglas configuradas</p><p class="text-[var(--color-text-secondary)] text-sm">Crea tu primera regla para recuperar clientes inactivos.</p>';
              list.appendChild(empty);
            }
          }
        });
      return;
    }

    var preset = t.closest('.days-preset');
    if (preset) { document.getElementById('rule-days').value = preset.dataset.days; return; }

    var varChip = t.closest('.var-chip');
    if (varChip) {
      var ta = document.getElementById('rule-message');
      var v = varChip.dataset.var;
      var pos = ta.selectionStart;
      ta.value = ta.value.slice(0, pos) + v + ta.value.slice(ta.selectionEnd);
      ta.selectionStart = ta.selectionEnd = pos + v.length;
      ta.focus();
      return;
    }

    if (t.closest('#rule-modal-save')) {
      var name = document.getElementById('rule-name').value.trim();
      var days = parseInt(document.getElementById('rule-days').value);
      var msg = document.getElementById('rule-message').value.trim();
      var mediaUrl = getMediaUrl();
      var editId = document.getElementById('rule-edit-id').value;
      var errEl = document.getElementById('rule-modal-error');

      if (!name || !days || !msg) {
        errEl.textContent = 'Completa nombre, días y mensaje.';
        errEl.classList.remove('hidden');
        return;
      }
      errEl.classList.add('hidden');

      var saveBtn = document.getElementById('rule-modal-save');
      saveBtn.disabled = true;
      saveBtn.textContent = 'Guardando...';

      var payload = { name: name, days_after_last_visit: days, message_text: msg, media_url: mediaUrl };
      var url = editId ? '/api/remarketing/rules/' + editId : '/api/remarketing/rules';
      var method = editId ? 'PUT' : 'POST';

      fetch(url, {
        method: method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      })
        .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, d: d }; }); })
        .then(function(result) {
          saveBtn.disabled = false;
          saveBtn.textContent = 'Guardar regla';
          if (result.ok) {
            var rule = { ...result.d, text: msg, media_url: mediaUrl };
            var list = document.getElementById('rules-list');
            if (editId) {
              var existing = document.querySelector('.rule-card[data-id="' + editId + '"]');
              if (existing) existing.replaceWith(buildRuleCard(rule));
            } else {
              var emptyEl = document.getElementById('rules-empty');
              if (emptyEl) emptyEl.remove();
              list.prepend(buildRuleCard(rule));
            }
            bindToggles();
            closeModal();
          } else {
            errEl.textContent = result.d.error || 'Error al guardar.';
            errEl.classList.remove('hidden');
          }
        })
        .catch(function() {
          saveBtn.disabled = false;
          saveBtn.textContent = 'Guardar regla';
          errEl.textContent = 'Error de conexión.';
          errEl.classList.remove('hidden');
        });
    }
  });

  // ── Toggles ────────────────────────────────────────────────────────────────
  function bindToggles() {
    document.querySelectorAll('.rule-toggle').forEach(function(toggle) {
      toggle.onchange = function() {
        var id = toggle.dataset.id;
        var active = toggle.checked;
        fetch('/api/remarketing/rules/' + id, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ is_active: active }),
        })
          .then(function(r) { return r.json(); })
          .then(function() {
            var card = document.querySelector('.rule-card[data-id="' + id + '"]');
            if (!card) return;
            var badge = card.querySelector('.rule-status-badge');
            if (badge) {
              badge.textContent = active ? '● Activa' : '○ Pausada';
              badge.className = 'inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold rule-status-badge ' + (active ? 'bg-green-500/20 text-green-400' : 'bg-[#2a2a3a] text-[var(--color-text-secondary)]');
            }
          })
          .catch(function() { toggle.checked = !active; });
      };
    });
  }
  bindToggles();

  // ── Send Now modal ─────────────────────────────────────────────────────────
  var _sendChannel = 'whatsapp';

  function setChannel(ch) {
    _sendChannel = ch;
    var waBtn = document.getElementById('channel-whatsapp');
    var smsBtn = document.getElementById('channel-sms');
    var mediaRow = document.getElementById('send-media-row');
    if (ch === 'whatsapp') {
      waBtn.className = 'channel-btn flex items-center justify-center gap-2 py-2.5 rounded-lg border-2 text-sm font-semibold transition-all border-[#25D366] bg-[#25D366]/10 text-white';
      smsBtn.className = 'channel-btn flex items-center justify-center gap-2 py-2.5 rounded-lg border-2 text-sm font-semibold transition-all border-[var(--color-border)] bg-[#1a1a25] text-[var(--color-text-secondary)]';
      if (mediaRow) mediaRow.classList.remove('hidden');
    } else {
      smsBtn.className = 'channel-btn flex items-center justify-center gap-2 py-2.5 rounded-lg border-2 text-sm font-semibold transition-all border-[#2563eb] bg-[#2563eb]/10 text-white';
      waBtn.className = 'channel-btn flex items-center justify-center gap-2 py-2.5 rounded-lg border-2 text-sm font-semibold transition-all border-[var(--color-border)] bg-[#1a1a25] text-[var(--color-text-secondary)]';
      if (mediaRow) mediaRow.classList.add('hidden'); // SMS media not shown
    }
  }

  document.getElementById('channel-whatsapp')?.addEventListener('click', function() { setChannel('whatsapp'); });
  document.getElementById('channel-sms')?.addEventListener('click', function() { setChannel('sms'); });

  function openSendModal() {
    _sendChannel = 'whatsapp';
    setChannel('whatsapp');
    document.getElementById('send-to').value = '+57';
    document.getElementById('send-message').value = '';
    document.getElementById('send-media-url').value = '';
    document.getElementById('send-error').classList.add('hidden');
    document.getElementById('send-success').classList.add('hidden');
    document.getElementById('send-char-count').textContent = '0';
    document.getElementById('send-modal').classList.remove('hidden');
    var toInput = document.getElementById('send-to');
    toInput.focus();
    toInput.setSelectionRange(toInput.value.length, toInput.value.length);
  }

  function closeSendModal() {
    document.getElementById('send-modal').classList.add('hidden');
  }

  var sendNowBtn = document.getElementById('btn-send-now');
  if (sendNowBtn) sendNowBtn.addEventListener('click', openSendModal);

  document.getElementById('send-modal-close')?.addEventListener('click', closeSendModal);
  document.getElementById('send-modal-cancel')?.addEventListener('click', closeSendModal);
  document.getElementById('send-modal-backdrop')?.addEventListener('click', closeSendModal);

  // Char counter
  document.getElementById('send-message')?.addEventListener('input', function() {
    document.getElementById('send-char-count').textContent = String(this.value.length);
  });

  document.getElementById('btn-do-send')?.addEventListener('click', function() {
    var to = document.getElementById('send-to').value.trim();
    var message = document.getElementById('send-message').value.trim();
    var mediaUrl = document.getElementById('send-media-url').value.trim();
    var errEl = document.getElementById('send-error');
    var successEl = document.getElementById('send-success');
    var btn = document.getElementById('btn-do-send');

    errEl.classList.add('hidden');
    successEl.classList.add('hidden');

    if (!to || !message) {
      errEl.textContent = 'El número y el mensaje son requeridos.';
      errEl.classList.remove('hidden');
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Enviando...';

    fetch('/api/remarketing/send', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ to: to, message: message, media_url: mediaUrl || null, channel: _sendChannel }),
    })
      .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, d: d }; }); })
      .then(function(result) {
        btn.disabled = false;
        btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg> Enviar';
        if (result.ok) {
          successEl.classList.remove('hidden');
          var d = result.d;
          var detail = document.getElementById('send-success-detail');
          var warn = document.getElementById('send-success-warn');
          var link = document.getElementById('send-twilio-link');
          if (detail) detail.textContent = 'SID: ' + (d.sid||'—') + ' · Estado: ' + (d.status||'—') + ' · De: ' + (d.from||'—') + ' → ' + (d.to||'—');
          if (d.error_code && warn) {
            warn.textContent = 'Twilio error ' + d.error_code + ': ' + (d.error_message || '');
            warn.classList.remove('hidden');
          }
          if (d.sid && link) {
            link.href = 'https://console.twilio.com/us1/monitor/logs/sms/' + d.sid;
            link.classList.remove('hidden');
          }
          // Warn about trial accounts
          if ((d.status === 'queued' || d.status === 'accepted') && warn && d.error_code === null) {
            warn.textContent = 'Estado: queued — Si no llega, tu cuenta Twilio puede ser de prueba. Verifica en la consola.';
            warn.classList.remove('hidden');
          }
          document.getElementById('send-to').value = '+57';
          document.getElementById('send-message').value = '';
          document.getElementById('send-media-url').value = '';
          document.getElementById('send-char-count').textContent = '0';
        } else {
          errEl.textContent = result.d.error || 'Error al enviar.';
          errEl.classList.remove('hidden');
        }
      })
      .catch(function() {
        btn.disabled = false;
        btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg> Enviar';
        errEl.textContent = 'Error de conexión.';
        errEl.classList.remove('hidden');
      });
  });
</script>

        <p class="text-2xl font-bold text-white">{totalClients}</p>
      </div>
      <div class="bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-xl p-5">
        <p class="text-xs text-[var(--color-text-secondary)] mb-1">Mensajes enviados</p>
        <p class="text-2xl font-bold text-green-400">{sentTotal}</p>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-6">
      <!-- Rules list -->

          class="w-full px-4 py-2.5 bg-[#1a1a25] border border-[var(--color-border)] rounded-lg text-white text-sm font-mono focus:outline-none focus:border-[#2563eb] transition-colors"
          placeholder="whatsapp:+15005550006" />
      </div>
      <div>
        <label class="block text-sm font-medium text-[#f0f0f5] mb-1.5">Número SMS <span class="text-[var(--color-text-secondary)] text-xs">(opcional · para envíos por SMS)</span></label>

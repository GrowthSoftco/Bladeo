---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { createAdminClient } from '@/lib/supabase';
import type { RemarketingRule } from '@/lib/types';

const barbershop = Astro.locals.barbershop;
const admin = createAdminClient();

// Check Twilio config
const { data: shopData } = await admin.from('barbershops').select('payment_details').eq('id', barbershop.id).single();
const twilioConfig = (shopData?.payment_details as any)?._twilio ?? null;
const twilioConfigured = !!(twilioConfig?.account_sid && twilioConfig?.auth_token && twilioConfig?.whatsapp_from);

// Parse template helper
function parseTemplate(tpl: string): { text: string; media_url: string | null } {
  try { const p = JSON.parse(tpl); return { text: p.text || tpl, media_url: p.media_url || null }; }
  catch { return { text: tpl, media_url: null }; }
}

// Stats + rules (only if configured)
let rules: RemarketingRule[] = [];
let inactiveClients = 0, totalClients = 0, sentTotal = 0, recentLogs: any[] = [];

if (twilioConfigured) {
  const { data: r } = await admin.from('remarketing_rules').select('*').eq('barbershop_id', barbershop.id).order('created_at', { ascending: false });
  rules = r ?? [];

  const thirtyDaysAgo = new Date(Date.now() - 30 * 24 * 60 * 60 * 1000).toISOString();
  const [{ count: ic }, { count: tc }, { count: st }, { data: logs }] = await Promise.all([
    admin.from('clients').select('*', { count: 'exact', head: true }).eq('barbershop_id', barbershop.id).or(`last_visit_at.lt.${thirtyDaysAgo},last_visit_at.is.null`),
    admin.from('clients').select('*', { count: 'exact', head: true }).eq('barbershop_id', barbershop.id),
    admin.from('remarketing_log').select('*', { count: 'exact', head: true }).eq('barbershop_id', barbershop.id).eq('status', 'sent'),
    admin.from('remarketing_log').select('*, clients(name, phone), remarketing_rules(name)').eq('barbershop_id', barbershop.id).order('created_at', { ascending: false }).limit(15),
  ]);
  inactiveClients = ic ?? 0;
  totalClients = tc ?? 0;
  sentTotal = st ?? 0;
  recentLogs = logs ?? [];
}

const barbershopId = barbershop.id;
const whatsappFromHint = twilioConfig?.whatsapp_from ?? '';
const rulesJson = JSON.stringify(rules.map(r => ({ ...r, ...parseTemplate(r.message_template) })));
---

<DashboardLayout title="Re-Marketing">


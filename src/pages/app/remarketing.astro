            placeholder="Escribe tu mensaje aquí..."
            class="w-full px-4 py-2.5 bg-[#1a1a25] border border-[var(--color-border)] rounded-lg text-white text-sm focus:outline-none focus:border-[#25D366] resize-none transition-colors"></textarea>
          <p class="text-xs text-[#555568] mt-1 text-right"><span id="send-char-count">0</span> caracteres</p>
        </div>

        <div id="send-media-row">
          <label class="block text-sm font-medium text-[#f0f0f5] mb-1.5">Imagen <span class="text-[var(--color-text-secondary)] text-xs">(opcional · URL pública)</span></label>
          <input type="url" id="send-media-url"
            placeholder="https://ejemplo.com/imagen.jpg"
            class="w-full px-4 py-2.5 bg-[#1a1a25] border border-[var(--color-border)] rounded-lg text-white text-sm font-mono focus:outline-none focus:border-[#25D366] transition-colors" />
        </div>

        <p id="send-error" class="text-red-400 text-sm hidden"></p>
        <div id="send-success" class="hidden bg-[#1a1a25] border border-[var(--color-border)] rounded-lg p-3 space-y-1">
          <p class="text-green-400 text-sm font-medium">✓ Twilio aceptó el mensaje</p>
          <p id="send-success-detail" class="text-xs text-[var(--color-text-secondary)] font-mono"></p>
          <p id="send-success-warn" class="text-xs text-amber-400 hidden"></p>
          <a id="send-twilio-link" href="#" target="_blank" rel="noopener" class="text-xs text-[#2563eb] hover:underline hidden">Ver en consola de Twilio →</a>
        </div>

        <div class="flex gap-3 pt-1">
          <button id="send-modal-cancel" class="flex-1 py-2.5 border border-[var(--color-border)] text-[var(--color-text-secondary)] hover:text-white rounded-lg text-sm transition-colors">Cancelar</button>

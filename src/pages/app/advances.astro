---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import AdvancesModule from '@/components/advances/AdvancesModule';
import type { Member } from '@/lib/types';

const member  = Astro.locals.member as Member;
const isOwner = member?.role === 'owner';
---
<DashboardLayout title="Anticipos">
  <div class="mb-8">
    <div class="flex items-center gap-3 mb-1">
      <div class="w-9 h-9 rounded-xl bg-[var(--color-brand)]/15 border border-[var(--color-brand)]/30 flex items-center justify-center">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-brand-light)]">
          <line x1="12" y1="1" x2="12" y2="23"/>
          <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
        </svg>
      </div>
      <div>
        <h1 class="text-2xl font-bold text-white">Anticipos de liquidación</h1>
        <p class="text-[var(--color-text-secondary)] text-sm">
          {isOwner
            ? 'Gestiona anticipos de tus barberos — se descontarán automáticamente en contabilidad'
            : 'Solicita un anticipo de tu liquidación'}
        </p>
      </div>
    </div>
  </div>

  <AdvancesModule
    client:load
    isOwner={isOwner}
    currentMemberId={member?.id ?? ''}
  />
</DashboardLayout>

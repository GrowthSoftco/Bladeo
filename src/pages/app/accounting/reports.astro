---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
const barbershop = Astro.locals.barbershop;
const barbershopName = barbershop?.name ?? 'Barbería';
---
<DashboardLayout title="Reportes">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-white mb-1">Reportes</h1>
    <p class="text-[var(--color-text-secondary)]">Genera y descarga reportes de contabilidad en PDF</p>
  </div>

  <div class="max-w-xl space-y-3" id="report-options">

    {[
      { id: 'all',   label: 'Todo hasta la fecha',    icon: 'M12 2v20M2 12h20', desc: 'Historial completo de ingresos y gastos' },
      { id: 'today', label: 'Hoy',                    icon: 'M12 2v20M2 12h20', desc: 'Resumen del día de hoy' },
      { id: 'date',  label: 'Fecha específica',       icon: 'M12 2v20M2 12h20', desc: 'Elige un día exacto' },
      { id: 'range', label: 'Rango de fechas',        icon: 'M12 2v20M2 12h20', desc: 'Selecciona fecha inicio y fin' },
      { id: '15d',   label: 'Últimos 15 días',        icon: 'M12 2v20M2 12h20', desc: 'Los 15 días anteriores a hoy' },
      { id: '30d',   label: 'Últimos 30 días',        icon: 'M12 2v20M2 12h20', desc: 'Los 30 días anteriores a hoy' },
    ].map(opt => (
      <div class="report-option bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-xl p-5 cursor-pointer hover:border-[#2563eb]/50 transition-all"
        data-id={opt.id}>
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-lg bg-[#1a1a25] border border-[var(--color-border)] flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8888a0" stroke-width="1.5">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-white text-sm">{opt.label}</p>
              <p class="text-xs text-[var(--color-text-secondary)] mt-0.5">{opt.desc}</p>
            </div>
          </div>
          <svg class="text-[var(--color-text-secondary)]" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
        </div>

        <!-- Date pickers (shown inline on selection) -->
        {opt.id === 'date' && (
          <div class="date-inputs hidden mt-4 pt-4 border-t border-[var(--color-border)]">
            <label class="block text-xs font-medium text-[var(--color-text-secondary)] mb-1.5">Fecha</label>
            <input type="date" class="single-date px-3 py-2 bg-[#1a1a25] border border-[var(--color-border)] rounded-lg text-white text-sm focus:outline-none focus:border-[#2563eb]" />
          </div>
        )}
        {opt.id === 'range' && (
          <div class="date-inputs hidden mt-4 pt-4 border-t border-[var(--color-border)]">
            <div class="flex items-center gap-3">
              <div class="flex-1">
                <label class="block text-xs font-medium text-[var(--color-text-secondary)] mb-1.5">Desde</label>
                <input type="date" class="range-from w-full px-3 py-2 bg-[#1a1a25] border border-[var(--color-border)] rounded-lg text-white text-sm focus:outline-none focus:border-[#2563eb]" />
              </div>
              <span class="text-[var(--color-text-secondary)] mt-5">→</span>
              <div class="flex-1">
                <label class="block text-xs font-medium text-[var(--color-text-secondary)] mb-1.5">Hasta</label>
                <input type="date" class="range-to w-full px-3 py-2 bg-[#1a1a25] border border-[var(--color-border)] rounded-lg text-white text-sm focus:outline-none focus:border-[#2563eb]" />
              </div>
            </div>
          </div>
        )}

        <!-- Download button (shown on selection) -->
        <div class="download-btn hidden mt-4">
          <button class="btn-download flex items-center gap-2 px-4 py-2.5 bg-[#2563eb] hover:bg-[#3b82f6] text-white font-semibold text-sm rounded-lg transition-colors w-full justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Descargar PDF
          </button>
        </div>
      </div>
    ))}
  </div>

  <!-- Loading overlay -->
  <div id="pdf-loading" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center">
    <div class="bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-2xl px-8 py-6 text-center">
      <svg class="animate-spin mx-auto mb-3 text-[#2563eb]" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
      <p class="text-white font-semibold">Generando PDF...</p>
      <p class="text-xs text-[var(--color-text-secondary)] mt-1">Esto puede tardar unos segundos</p>
    </div>
  </div>
</DashboardLayout>

<script define:vars={{ barbershopName }}>
  var selected = null;

  document.querySelectorAll('.report-option').forEach(function(opt) {
    opt.addEventListener('click', function(e) {
      // Don't toggle if clicking inside inputs or button
      if (e.target.closest('input') || e.target.closest('.btn-download')) return;

      var id = opt.dataset.id;

      // Collapse all others
      document.querySelectorAll('.report-option').forEach(function(o) {
        if (o !== opt) {
          o.classList.remove('border-[#2563eb]', 'bg-[#2563eb]/5');
          o.classList.add('border-[var(--color-border)]');
          o.querySelector('.date-inputs')?.classList.add('hidden');
          o.querySelector('.download-btn')?.classList.add('hidden');
        }
      });

      if (selected === id) {
        // Collapse self
        opt.classList.remove('border-[#2563eb]', 'bg-[#2563eb]/5');
        opt.classList.add('border-[var(--color-border)]');
        opt.querySelector('.date-inputs')?.classList.add('hidden');
        opt.querySelector('.download-btn')?.classList.add('hidden');
        selected = null;
        return;
      }

      selected = id;
      opt.classList.add('border-[#2563eb]', 'bg-[#2563eb]/5');
      opt.classList.remove('border-[var(--color-border)]');
      opt.querySelector('.date-inputs')?.classList.remove('hidden');
      opt.querySelector('.download-btn')?.classList.remove('hidden');
    });

    opt.querySelector('.btn-download')?.addEventListener('click', function() {
      var id = opt.dataset.id;
      var today = new Date().toISOString().split('T')[0];
      var from, to;

      if (id === 'all') {
        from = '2020-01-01'; to = today;
      } else if (id === 'today') {
        from = today; to = today;
      } else if (id === 'date') {
        var d = opt.querySelector('.single-date').value;
        if (!d) { alert('Selecciona una fecha.'); return; }
        from = d; to = d;
      } else if (id === 'range') {
        from = opt.querySelector('.range-from').value;
        to = opt.querySelector('.range-to').value;
        if (!from || !to) { alert('Selecciona las dos fechas.'); return; }
        if (from > to) { alert('La fecha de inicio debe ser antes que la fecha fin.'); return; }
      } else if (id === '15d') {
        var d15 = new Date(); d15.setDate(d15.getDate() - 15);
        from = d15.toISOString().split('T')[0]; to = today;
      } else if (id === '30d') {
        var d30 = new Date(); d30.setDate(d30.getDate() - 30);
        from = d30.toISOString().split('T')[0]; to = today;
      }

      downloadPDF(from, to, id);
    });
  });

  function downloadPDF(from, to, reportId) {
    document.getElementById('pdf-loading').classList.remove('hidden');

    fetch('/api/accounting/report-pdf?from=' + from + '&to=' + to)
      .then(function(r) {
        if (!r.ok) return r.json().then(function(d) { throw new Error(d.error || 'Error'); });
        return r.text();
      })
      .then(function(html) {
        document.getElementById('pdf-loading').classList.add('hidden');
        // Open in new tab and trigger print dialog (Save as PDF)
        var win = window.open('', '_blank');
        win.document.write(html);
        win.document.close();
        win.onload = function() { win.print(); };
      })
      .catch(function(err) {
        document.getElementById('pdf-loading').classList.add('hidden');
        alert('Error al generar reporte: ' + err.message);
      });
  }
</script>

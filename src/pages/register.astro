---
import AuthLayout from '@/layouts/AuthLayout.astro';

if (Astro.locals.user) {
  return Astro.redirect('/app/plans');
}
---

<AuthLayout title="Crear cuenta">
  <div>
    <h2 class="text-2xl font-bold text-white mb-1">Crea tu cuenta</h2>
    <p class="text-[#8888a0] mb-8">Comienza gratis. Sin tarjeta requerida para registrarte.</p>

    <!-- Step indicator -->
    <div class="flex items-center gap-3 mb-8">
      <div class="flex items-center gap-2">
        <div id="step1-indicator" class="w-7 h-7 rounded-full bg-brand flex items-center justify-center text-white text-xs font-bold">1</div>
        <span id="step1-label" class="text-sm font-medium text-white">Tu cuenta</span>
      </div>
      <div class="flex-1 h-px bg-[#2a2a3a]"></div>
      <div class="flex items-center gap-2">
        <div id="step2-indicator" class="w-7 h-7 rounded-full bg-[#2a2a3a] flex items-center justify-center text-[#8888a0] text-xs font-bold">2</div>
        <span id="step2-label" class="text-sm font-medium text-[#8888a0]">Tu barbería</span>
      </div>
    </div>

    <div id="error-banner" class="hidden mb-5 px-4 py-3 bg-danger/10 border border-danger/30 rounded-lg text-danger text-sm"></div>

    <!-- Step 1 -->
    <form id="step1-form" class="space-y-5">
      <div>
        <label for="email" class="block text-sm font-medium text-[#f0f0f5] mb-1.5">Correo electrónico</label>
        <input type="email" id="email" name="email" required autocomplete="email" placeholder="nombre@ejemplo.com"
          class="w-full px-4 py-3 bg-[#1a1a25] border border-[#2a2a3a] rounded-lg text-white placeholder-[#8888a0] focus:outline-none focus:border-brand transition-colors" />
      </div>
      <div>
        <label for="password" class="block text-sm font-medium text-[#f0f0f5] mb-1.5">Contraseña</label>
        <div class="relative">
          <input type="password" id="password" name="password" required autocomplete="new-password" placeholder="Mínimo 8 caracteres"
            class="w-full px-4 py-3 bg-[#1a1a25] border border-[#2a2a3a] rounded-lg text-white placeholder-[#8888a0] focus:outline-none focus:border-brand transition-colors pr-12" />
          <button type="button" id="toggle-pw1" class="absolute right-3 top-1/2 -translate-y-1/2 text-[#8888a0] hover:text-white transition-colors">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle>
            </svg>
          </button>
        </div>
        <div class="mt-2 flex gap-1">
          <div id="str-1" class="h-1 flex-1 rounded-full bg-[#2a2a3a]"></div>
          <div id="str-2" class="h-1 flex-1 rounded-full bg-[#2a2a3a]"></div>
          <div id="str-3" class="h-1 flex-1 rounded-full bg-[#2a2a3a]"></div>
          <div id="str-4" class="h-1 flex-1 rounded-full bg-[#2a2a3a]"></div>
        </div>
      </div>
      <div>
        <label for="confirm-password" class="block text-sm font-medium text-[#f0f0f5] mb-1.5">Confirmar contraseña</label>
        <div class="relative">
          <input type="password" id="confirm-password" name="confirm-password" required autocomplete="new-password" placeholder="Repite tu contraseña"
            class="w-full px-4 py-3 bg-[#1a1a25] border border-[#2a2a3a] rounded-lg text-white placeholder-[#8888a0] focus:outline-none focus:border-brand transition-colors pr-12" />
          <button type="button" id="toggle-pw2" class="absolute right-3 top-1/2 -translate-y-1/2 text-[#8888a0] hover:text-white transition-colors">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle>
            </svg>
          </button>
        </div>
      </div>
      <button type="submit" class="w-full py-3 px-6 bg-brand hover:bg-brand-light text-white font-semibold rounded-lg transition-colors">
        Continuar
      </button>
    </form>

    <!-- Step 2 -->
    <form id="step2-form" class="space-y-5 hidden">
      <div>
        <label for="owner-name" class="block text-sm font-medium text-[#f0f0f5] mb-1.5">Tu nombre</label>
        <input type="text" id="owner-name" required placeholder="Juan Pérez"
          class="w-full px-4 py-3 bg-[#1a1a25] border border-[#2a2a3a] rounded-lg text-white placeholder-[#8888a0] focus:outline-none focus:border-brand transition-colors" />
      </div>
      <div>
        <label for="shop-name" class="block text-sm font-medium text-[#f0f0f5] mb-1.5">Nombre de la barbería</label>
        <input type="text" id="shop-name" required placeholder="Ej: Classic Cuts Barbershop"
          class="w-full px-4 py-3 bg-[#1a1a25] border border-[#2a2a3a] rounded-lg text-white placeholder-[#8888a0] focus:outline-none focus:border-brand transition-colors" />
        <p class="mt-1 text-xs text-[#8888a0]">URL pública: bladeo.app/b/<span id="slug-preview">tu-barberia</span></p>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="phone" class="block text-sm font-medium text-[#f0f0f5] mb-1.5">Teléfono</label>
          <input type="tel" id="phone" placeholder="300 123 4567"
            class="w-full px-4 py-3 bg-[#1a1a25] border border-[#2a2a3a] rounded-lg text-white placeholder-[#8888a0] focus:outline-none focus:border-brand transition-colors" />
        </div>
        <div>
          <label for="city" class="block text-sm font-medium text-[#f0f0f5] mb-1.5">Ciudad</label>
          <input type="text" id="city" value="Pereira" placeholder="Pereira"
            class="w-full px-4 py-3 bg-[#1a1a25] border border-[#2a2a3a] rounded-lg text-white placeholder-[#8888a0] focus:outline-none focus:border-brand transition-colors" />
        </div>
      </div>
      <div class="flex gap-3">
        <button type="button" id="back-btn" class="flex-1 py-3 px-6 bg-[#1a1a25] border border-[#2a2a3a] text-white font-semibold rounded-lg transition-colors hover:bg-[#2a2a3a]">
          Atrás
        </button>
        <button type="submit" id="create-btn" class="flex-1 py-3 px-6 bg-brand hover:bg-brand-light text-white font-semibold rounded-lg transition-colors flex items-center justify-center gap-2 disabled:opacity-60">
          <span id="create-text">Crear cuenta</span>
          <span id="create-spinner" class="hidden">
            <svg class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
          </span>
        </button>
      </div>
    </form>

    <p class="text-center text-[#8888a0] text-sm mt-6">
      ¿Ya tienes cuenta?{' '}
      <a href="/login" class="text-brand hover:text-brand-light font-medium transition-colors">Inicia sesión</a>
    </p>
  </div>
</AuthLayout>

<script>
  function slugify(text: string) {
    return text.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9\s-]/g, '').trim().replace(/\s+/g, '-').replace(/-+/g, '-');
  }

  const step1Form = document.getElementById('step1-form') as HTMLFormElement;
  const step2Form = document.getElementById('step2-form') as HTMLFormElement;
  const errorBanner = document.getElementById('error-banner') as HTMLDivElement;

  // Password strength
  const pwInput = document.getElementById('password') as HTMLInputElement;
  pwInput.addEventListener('input', () => {
    const val = pwInput.value;
    let strength = 0;
    if (val.length >= 8) strength++;
    if (/[A-Z]/.test(val)) strength++;
    if (/[0-9]/.test(val)) strength++;
    if (/[^A-Za-z0-9]/.test(val)) strength++;
    const colors = ['bg-danger', 'bg-warning', 'bg-yellow-400', 'bg-success'];
    for (let i = 1; i <= 4; i++) {
      const el = document.getElementById(`str-${i}`) as HTMLDivElement;
      el.className = `h-1 flex-1 rounded-full ${i <= strength ? colors[strength - 1] : 'bg-[#2a2a3a]'}`;
    }
  });

  // Slug preview
  const shopNameInput = document.getElementById('shop-name') as HTMLInputElement;
  const slugPreview = document.getElementById('slug-preview') as HTMLSpanElement;
  shopNameInput.addEventListener('input', () => {
    slugPreview.textContent = slugify(shopNameInput.value) || 'tu-barberia';
  });

  // Toggle passwords
  document.getElementById('toggle-pw1')?.addEventListener('click', () => {
    pwInput.type = pwInput.type === 'password' ? 'text' : 'password';
  });
  document.getElementById('toggle-pw2')?.addEventListener('click', () => {
    const cp = document.getElementById('confirm-password') as HTMLInputElement;
    cp.type = cp.type === 'password' ? 'text' : 'password';
  });

  // Step 1 → Step 2
  step1Form.addEventListener('submit', (e) => {
    e.preventDefault();
    errorBanner.classList.add('hidden');
    const pw = pwInput.value;
    const cpw = (document.getElementById('confirm-password') as HTMLInputElement).value;
    if (pw.length < 8) { errorBanner.textContent = 'La contraseña debe tener al menos 8 caracteres.'; errorBanner.classList.remove('hidden'); return; }
    if (pw !== cpw) { errorBanner.textContent = 'Las contraseñas no coinciden.'; errorBanner.classList.remove('hidden'); return; }

    step1Form.classList.add('hidden');
    step2Form.classList.remove('hidden');
    document.getElementById('step2-indicator')!.className = 'w-7 h-7 rounded-full bg-brand flex items-center justify-center text-white text-xs font-bold';
    document.getElementById('step2-label')!.className = 'text-sm font-medium text-white';
  });

  document.getElementById('back-btn')?.addEventListener('click', () => {
    step2Form.classList.add('hidden');
    step1Form.classList.remove('hidden');
  });

  // Step 2 submit
  step2Form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorBanner.classList.add('hidden');

    const createBtn = document.getElementById('create-btn') as HTMLButtonElement;
    const createText = document.getElementById('create-text') as HTMLSpanElement;
    const createSpinner = document.getElementById('create-spinner') as HTMLSpanElement;
    createBtn.disabled = true;
    createText.textContent = 'Creando cuenta...';
    createSpinner.classList.remove('hidden');

    const email = (document.getElementById('email') as HTMLInputElement).value;
    const password = pwInput.value;
    const ownerName = (document.getElementById('owner-name') as HTMLInputElement).value;
    const shopName = shopNameInput.value;
    const phone = (document.getElementById('phone') as HTMLInputElement).value;
    const city = (document.getElementById('city') as HTMLInputElement).value;

    try {
      const res = await fetch('/api/auth/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password, ownerName, shopName, phone, city }),
      });
      const data = await res.json();

      if (!res.ok) throw new Error(data.error ?? 'Error al crear la cuenta.');

      // Store session in cookies
      document.cookie = `sb-access-token=${data.session.access_token}; path=/; max-age=${60 * 60 * 24 * 7}; SameSite=Lax`;
      document.cookie = `sb-refresh-token=${data.session.refresh_token}; path=/; max-age=${60 * 60 * 24 * 30}; SameSite=Lax`;
      window.location.href = '/app/plans';
    } catch (err: any) {
      errorBanner.textContent = err.message;
      errorBanner.classList.remove('hidden');
      createBtn.disabled = false;
      createText.textContent = 'Crear cuenta';
      createSpinner.classList.add('hidden');
    }
  });
</script>

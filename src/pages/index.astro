---
import PublicLayout from '@/layouts/PublicLayout.astro';
---

<PublicLayout title="Bladeo — La plataforma para barberías modernas" description="Gestiona tu barbería con Bladeo: agenda, POS, clientes, fidelización, analítica y más. Empieza hoy.">
  <!-- Nav -->
  <nav class="flex items-center justify-between px-6 py-5 max-w-6xl mx-auto">
    <div class="flex items-center gap-3">
      <div class="w-9 h-9 bg-[#2563eb] rounded-lg flex items-center justify-center">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
          <path d="M6 3l2 4-2 4 2 4-2 4" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M12 3v18" stroke="white" stroke-width="2" stroke-linecap="round"/>
          <path d="M18 3l-2 4 2 4-2 4 2 4" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <span class="text-xl font-bold text-white">Bladeo</span>
    </div>
    <div class="flex items-center gap-4">
      <a href="/login" class="text-sm text-[#8888a0] hover:text-white transition-colors">Iniciar sesión</a>
      <a href="/register" class="text-sm bg-[#2563eb] hover:bg-[#3b82f6] text-white font-semibold px-4 py-2 rounded-lg transition-colors">
        Comenzar gratis
      </a>
    </div>
  </nav>

  <!-- Hero -->
  <section class="max-w-6xl mx-auto px-6 py-20 text-center">
    <div class="inline-flex items-center gap-2 bg-[#2563eb]/10 border border-[#2563eb]/20 rounded-full px-4 py-1.5 text-sm text-[#3b82f6] font-medium mb-8">
      <span class="w-2 h-2 rounded-full bg-[#22c55e] animate-pulse"></span>
      Plataforma para barberías en Colombia
    </div>
    <h1 class="text-5xl md:text-6xl font-bold text-white leading-tight mb-6">
      Tu barbería,<br/>
      <span class="text-[#2563eb]">profesionalizada.</span>
    </h1>
    <p class="text-[#8888a0] text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
      Gestiona citas, clientes, ventas y tu equipo desde un solo lugar. La herramienta que tu barbería necesita para crecer.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/register" class="px-8 py-4 bg-[#2563eb] hover:bg-[#3b82f6] text-white font-bold text-lg rounded-xl transition-colors">
        Comenzar ahora
      </a>
      <a href="#features" class="px-8 py-4 bg-[#1a1a25] hover:bg-[#2a2a3a] border border-[#2a2a3a] text-white font-semibold text-lg rounded-xl transition-colors">
        Ver características
      </a>
    </div>
  </section>

  <!-- Features grid -->
  <section id="features" class="max-w-6xl mx-auto px-6 py-16">
    <h2 class="text-3xl font-bold text-white text-center mb-4">Todo lo que necesitas</h2>
    <p class="text-[#8888a0] text-center mb-12">En un solo lugar, sin complicaciones.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {[
        { icon: '📅', title: 'Agenda Inteligente', desc: 'Calendarios por barbero, citas en tiempo real, booking público para que tus clientes agenden solos.' },
        { icon: '💰', title: 'Punto de Venta', desc: 'Registra ventas de servicios y productos, acepta múltiples métodos de pago, genera recibos.' },
        { icon: '👥', title: 'Gestión de Clientes', desc: 'Historial completo de visitas, gasto total, notas y programa de fidelización automático.' },
        { icon: '📊', title: 'War Room', desc: 'Ranking de barberos, ingresos por período, heatmap de horas pico, tasa de retención.' },
        { icon: '📢', title: 'Re-Marketing', desc: 'Campañas automáticas para traer de vuelta clientes que no han visitado en 15, 30 o 60 días.' },
        { icon: '🏦', title: 'Corresponsal Bancario', desc: 'Módulo completo para barberías que operan como corresponsal: registro, cuadre de caja, reportes.' },
      ].map(f => (
        <div class="bg-[#12121a] border border-[#2a2a3a] rounded-2xl p-6 hover:border-[#2563eb]/30 transition-colors">
          <div class="text-3xl mb-4">{f.icon}</div>
          <h3 class="text-lg font-semibold text-white mb-2">{f.title}</h3>
          <p class="text-[#8888a0] text-sm leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Pricing -->
  <section class="max-w-5xl mx-auto px-6 py-16">
    <h2 class="text-3xl font-bold text-white text-center mb-4">Precios simples y transparentes</h2>
    <p class="text-[#8888a0] text-center mb-12">Sin costos ocultos. Cancela cuando quieras.</p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {[
        { name: 'Básico', price: '79.900', desc: 'Para el dueño que trabaja solo', highlight: false },
        { name: 'Pro', price: '149.900', desc: 'Para equipos de hasta 5 barberos', highlight: true },
        { name: 'Elite', price: '249.900', desc: 'Para barberías en crecimiento', highlight: false },
      ].map(p => (
        <div class={`rounded-2xl p-6 border ${p.highlight ? 'bg-[#12121a] border-[#2563eb] relative' : 'bg-[#12121a] border-[#2a2a3a]'}`}>
          {p.highlight && <div class="absolute -top-3.5 left-1/2 -translate-x-1/2 bg-[#2563eb] text-white text-xs font-bold px-4 py-1.5 rounded-full">Más popular</div>}
          <h3 class="text-lg font-bold text-white mb-1">{p.name}</h3>
          <p class="text-[#8888a0] text-sm mb-4">{p.desc}</p>
          <div class="flex items-end gap-1 mb-6">
            <span class="text-2xl font-bold text-white">${p.price}</span>
            <span class="text-[#8888a0] text-sm mb-0.5">/mes</span>
          </div>
          <a href="/register" class={`block text-center py-2.5 px-5 rounded-xl font-semibold text-sm transition-colors ${p.highlight ? 'bg-[#2563eb] hover:bg-[#3b82f6] text-white' : 'bg-[#1a1a25] hover:bg-[#2a2a3a] border border-[#2a2a3a] text-white'}`}>
            Comenzar
          </a>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-3xl mx-auto px-6 py-16 text-center">
    <h2 class="text-3xl font-bold text-white mb-4">Profesionaliza tu barbería hoy</h2>
    <p class="text-[#8888a0] text-lg mb-8">Únete a los barberos que ya gestionan su negocio con Bladeo.</p>
    <a href="/register" class="inline-block px-10 py-4 bg-[#2563eb] hover:bg-[#3b82f6] text-white font-bold text-lg rounded-xl transition-colors">
      Crear cuenta gratis
    </a>
  </section>

  <!-- Footer -->
  <footer class="border-t border-[#2a2a3a] px-6 py-8 text-center text-[#8888a0] text-sm">
    <p>© 2026 Bladeo. Todos los derechos reservados.</p>
    <div class="flex items-center justify-center gap-6 mt-3">
      <a href="/terms" class="hover:text-white transition-colors">Términos</a>
      <a href="/privacy" class="hover:text-white transition-colors">Privacidad</a>
    </div>
  </footer>
</PublicLayout>

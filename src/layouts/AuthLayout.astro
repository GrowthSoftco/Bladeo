---
import '@/styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Bladeo' } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Bladeo</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="min-h-screen bg-[#0a0a0f] flex">
  <!-- Left side: branding illustration -->
  <div class="hidden lg:flex lg:w-1/2 xl:w-[55%] relative overflow-hidden bg-gradient-to-br from-[#0a0a0f] via-[#0d1117] to-[#0a1628]">
    <!-- Grid overlay -->
    <div
      class="absolute inset-0 opacity-10"
      style="background-image: linear-gradient(rgba(37,99,235,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(37,99,235,0.3) 1px, transparent 1px); background-size: 60px 60px;"
    ></div>

    <!-- Gradient orb top -->
    <div class="absolute top-[-10%] left-[20%] w-[500px] h-[500px] bg-brand/20 rounded-full blur-[120px]"></div>
    <!-- Gradient orb bottom -->
    <div class="absolute bottom-[-15%] right-[10%] w-[400px] h-[400px] bg-brand-dark/15 rounded-full blur-[100px]"></div>

    <!-- Content -->
    <div class="relative z-10 flex flex-col justify-between p-12 w-full">
      <!-- Logo -->
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-brand rounded-lg flex items-center justify-center">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M6 3l2 4-2 4 2 4-2 4" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M12 3v18" stroke="white" stroke-width="2" stroke-linecap="round"/>
            <path d="M18 3l-2 4 2 4-2 4 2 4" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <span class="text-2xl font-bold text-white tracking-tight">Bladeo</span>
      </div>

      <!-- Center illustration area -->
      <div class="flex flex-col items-center justify-center flex-1 text-center px-8">
        <!-- Scissors icon large -->
        <div class="mb-8 opacity-90">
          <svg width="120" height="120" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="60" cy="60" r="56" fill="rgba(37,99,235,0.08)" stroke="rgba(37,99,235,0.2)" stroke-width="1"/>
            <circle cx="38" cy="42" r="10" stroke="#2563eb" stroke-width="2" fill="none"/>
            <circle cx="38" cy="78" r="10" stroke="#2563eb" stroke-width="2" fill="none"/>
            <line x1="46" y1="49" x2="82" y2="72" stroke="#3b82f6" stroke-width="2" stroke-linecap="round"/>
            <line x1="46" y1="71" x2="82" y2="48" stroke="#3b82f6" stroke-width="2" stroke-linecap="round"/>
            <circle cx="82" cy="60" r="3" fill="#2563eb"/>
          </svg>
        </div>

        <h1 class="text-3xl font-bold text-white mb-4 leading-tight">
          Tu barbería,<br/>
          <span class="text-brand">profesionalizada.</span>
        </h1>
        <p class="text-text-secondary text-lg max-w-sm leading-relaxed">
          Gestiona citas, clientes, ventas y más en un solo lugar. La plataforma pensada para barberías modernas.
        </p>

        <!-- Feature pills -->
        <div class="flex flex-wrap gap-2 mt-8 justify-center">
          {['Agenda inteligente', 'POS integrado', 'Fidelización', 'Analítica', 'Booking público'].map(feature => (
            <span class="px-3 py-1 bg-brand/10 border border-brand/20 rounded-full text-brand-light text-sm font-medium">
              {feature}
            </span>
          ))}
        </div>
      </div>

      <!-- Testimonial -->
      <div class="bg-white/5 border border-white/10 rounded-xl p-6 backdrop-blur-sm">
        <p class="text-white/80 text-sm italic leading-relaxed mb-3">
          "Bladeo transformó cómo manejo mi barbería. Ahora mis clientes agendan solos y yo me enfoco en lo que sé hacer."
        </p>
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-full bg-brand/30 flex items-center justify-center text-xs font-bold text-white">JR</div>
          <div>
            <p class="text-white text-sm font-medium">Julián Ríos</p>
            <p class="text-text-secondary text-xs">Barber Shop Jr., Pereira</p>
          </div>
          <div class="ml-auto flex gap-0.5">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Right side: form -->
  <div class="w-full lg:w-1/2 xl:w-[45%] flex items-center justify-center p-6 sm:p-10 bg-[#0a0a0f]">
    <div class="w-full max-w-md">
      <!-- Mobile logo -->
      <div class="flex items-center gap-3 mb-10 lg:hidden">
        <div class="w-9 h-9 bg-brand rounded-lg flex items-center justify-center">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <path d="M6 3l2 4-2 4 2 4-2 4" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M12 3v18" stroke="white" stroke-width="2" stroke-linecap="round"/>
            <path d="M18 3l-2 4 2 4-2 4 2 4" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <span class="text-xl font-bold text-white">Bladeo</span>
      </div>

      <slot />

      <!-- Footer links -->
      <p class="text-center text-text-secondary text-xs mt-8">
        Al continuar, aceptas nuestros{' '}
        <a href="/terms" class="text-brand hover:underline">Términos de servicio</a>
        {' '}y la{' '}
        <a href="/privacy" class="text-brand hover:underline">Política de privacidad</a>.
      </p>
    </div>
  </div>
</body>
</html>

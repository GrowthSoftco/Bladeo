---
import '@/styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Bladeo' } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Bladeo</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="min-h-screen bg-[#0a0a0f] flex">
  <!-- Left side: barbershop photo -->
  <div class="hidden lg:block lg:w-1/2 xl:w-[55%] relative overflow-hidden">
    <!-- Photo -->
    <img
      src="https://res.cloudinary.com/dfp4cw5bq/image/upload/v1777670276/Group_67_wvmqbx.png"
      alt="Barbería"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <!-- Dark overlay for depth -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-black/40"></div>

    <!-- Logo top-left -->
    <div class="absolute top-10 left-10 z-10 flex items-center gap-3">
      <div class="w-10 h-10 bg-brand rounded-lg flex items-center justify-center shadow-lg">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
          <path d="M6 3l2 4-2 4 2 4-2 4" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M12 3v18" stroke="white" stroke-width="2" stroke-linecap="round"/>
          <path d="M18 3l-2 4 2 4-2 4 2 4" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <span class="text-2xl font-bold text-white tracking-tight drop-shadow">Bladeo</span>
    </div>

  </div>

  <!-- Right side: form -->
  <div class="w-full lg:w-1/2 xl:w-[45%] flex items-center justify-center p-6 sm:p-10 bg-[#0a0a0f]">
    <div class="w-full max-w-md">
      <!-- Mobile logo -->
      <div class="flex items-center gap-3 mb-10 lg:hidden">
        <div class="w-9 h-9 bg-brand rounded-lg flex items-center justify-center">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <path d="M6 3l2 4-2 4 2 4-2 4" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M12 3v18" stroke="white" stroke-width="2" stroke-linecap="round"/>
            <path d="M18 3l-2 4 2 4-2 4 2 4" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <span class="text-xl font-bold text-white">Bladeo</span>
      </div>

      <slot />

      <!-- Footer links -->
      <p class="text-center text-text-secondary text-xs mt-8">
        Al continuar, aceptas nuestros{' '}
        <a href="/terms" class="text-brand hover:underline">Términos de servicio</a>
        {' '}y la{' '}
        <a href="/privacy" class="text-brand hover:underline">Política de privacidad</a>.
      </p>
    </div>
  </div>
</body>
</html>

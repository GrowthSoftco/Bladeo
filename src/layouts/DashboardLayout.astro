  <!-- ===================== EXPENSE MODAL (Feature #2) ===================== -->
  <div
    id="expense-modal"
    class="hidden fixed inset-0 z-[60] flex items-center justify-center p-4 bg-black/60"
    onclick="handleExpenseModalBackdrop(event)"
  >
    <div class="bg-[var(--color-surface-overlay)] border border-[var(--color-border)] rounded-2xl w-full max-w-md shadow-2xl" id="expense-modal-inner">
      <div class="flex items-center justify-between px-6 py-4 border-b border-[var(--color-border)]">
        <h2 class="text-base font-semibold text-white">Registrar gasto</h2>
        <button
          onclick="closeExpenseModal()"
          class="w-8 h-8 flex items-center justify-center rounded-lg text-[var(--color-text-secondary)] hover:text-white hover:bg-[var(--color-surface-elevated)] transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
      <form id="expense-form" class="px-6 py-5 space-y-4" onsubmit="submitExpense(event)">
        <div>
          <label class="block text-xs font-semibold text-[var(--color-text-secondary)] uppercase tracking-wider mb-1.5">Categoría</label>
          <select
            name="category"
            required
            class="w-full bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-lg px-3 py-2.5 text-sm text-white focus:outline-none focus:border-[var(--color-brand)] transition-colors appearance-none"
          >
            <option value="" disabled selected>Seleccionar categoría</option>
            <option value="Arriendo">Arriendo</option>
            <option value="Servicios públicos">Servicios públicos</option>
            <option value="Insumos">Insumos</option>
            <option value="Salarios">Salarios</option>
            <option value="Publicidad">Publicidad</option>
            <option value="Mantenimiento">Mantenimiento</option>
            <option value="Equipos">Equipos</option>
            <option value="Otro">Otro</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-semibold text-[var(--color-text-secondary)] uppercase tracking-wider mb-1.5">Descripción</label>
          <input
            type="text"
            name="description"
            placeholder="Ej. Pago de arriendo mensual"
            class="w-full bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-lg px-3 py-2.5 text-sm text-white placeholder-[#8888a0] focus:outline-none focus:border-[var(--color-brand)] transition-colors"
          />
        </div>
        <div>
          <label class="block text-xs font-semibold text-[var(--color-text-secondary)] uppercase tracking-wider mb-1.5">Monto</label>
          <input
            type="number"
            name="amount"
            min="0"
            step="0.01"
            placeholder="0.00"
            required
            class="w-full bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-lg px-3 py-2.5 text-sm text-white placeholder-[#8888a0] focus:outline-none focus:border-[var(--color-brand)] transition-colors"
          />
        </div>
        <div>
          <label class="block text-xs font-semibold text-[var(--color-text-secondary)] uppercase tracking-wider mb-1.5">Fecha</label>
          <input
            type="date"
            name="date"
            id="expense-date"
            required
            class="w-full bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-lg px-3 py-2.5 text-sm text-white focus:outline-none focus:border-[var(--color-brand)] transition-colors"
          />
        </div>
        <div id="expense-error" class="hidden text-sm text-red-400 bg-red-500/10 rounded-lg px-3 py-2"></div>
        <div class="flex gap-3 pt-1">
          <button
            type="button"
            onclick="closeExpenseModal()"
            class="flex-1 px-4 py-2.5 rounded-lg text-sm font-medium text-[var(--color-text-secondary)] bg-[var(--color-surface-elevated)] hover:bg-[var(--color-surface-elevated)] transition-colors border border-[var(--color-border)]"
          >
            Cancelar
          </button>
          <button
            type="submit"
            id="expense-submit-btn"
            class="flex-1 px-4 py-2.5 rounded-lg text-sm font-medium text-white bg-[var(--color-brand)] hover:opacity-90 transition-opacity"
          >
            Guardar gasto
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- ===================== BOOKING TOAST ===================== -->
  <div id="booking-toast" style="display:none;position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%);z-index:9998;max-width:24rem;width:calc(100% - 2rem);">
    <div id="booking-toast-inner" style="background:var(--color-surface-elevated);border:1px solid var(--color-brand);border-radius:0.875rem;box-shadow:0 8px 40px rgba(0,0,0,0.4);overflow:hidden;opacity:0;transform:translateY(20px);transition:opacity 250ms ease,transform 250ms ease;">
      <!-- Clickable area: opens the agenda on the appointment's date -->
      <a id="booking-toast-link" href="/app/agenda" style="display:flex;align-items:center;gap:0.875rem;padding:0.875rem 0.875rem 0.75rem;text-decoration:none;cursor:pointer;">
        <div style="width:2.25rem;height:2.25rem;border-radius:0.625rem;background:color-mix(in srgb,var(--color-brand) 20%,transparent);display:flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--color-brand-light);">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
          </svg>
        </div>
        <div style="flex:1;min-width:0;">
          <p style="margin:0;font-size:0.8125rem;font-weight:700;color:var(--color-text-primary);letter-spacing:0.01em;">Nueva reserva · <span style="font-size:0.75rem;font-weight:500;color:var(--color-brand-light);">Ver agenda →</span></p>
          <p id="booking-toast-body" style="margin:0.2rem 0 0;font-size:0.8125rem;color:var(--color-text-secondary);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"></p>
        </div>
        <button onclick="event.preventDefault();event.stopPropagation();dismissBookingToast();" style="flex-shrink:0;width:1.75rem;height:1.75rem;border:1px solid var(--color-border);background:var(--color-surface-overlay);border-radius:0.375rem;cursor:pointer;color:var(--color-text-secondary);font-size:1.125rem;line-height:1;display:flex;align-items:center;justify-content:center;" title="Cerrar">×</button>
      </a>
      <div id="booking-toast-bar" style="height:2px;background:var(--color-brand);transform-origin:left;transform:scaleX(1);"></div>
    </div>
  </div>

  <!-- ===================== ALL SCRIPTS ===================== -->
  <script is:inline>
    // ── Sidebar open/close (mobile) ──────────────────────────────────────────
    function openSidebar() {
      document.getElementById('sidebar').classList.remove('-translate-x-full');
      document.getElementById('sidebar-overlay').classList.remove('hidden');
    }
    function closeSidebar() {
      document.getElementById('sidebar').classList.add('-translate-x-full');
      document.getElementById('sidebar-overlay').classList.add('hidden');
    }

    // ── Feature #6: Sidebar collapse ─────────────────────────────────────────
    function toggleSidebarCollapse() {
      var isCollapsed = document.documentElement.getAttribute('data-sidebar-collapsed') === 'true';
      if (isCollapsed) {
        document.documentElement.removeAttribute('data-sidebar-collapsed');
        localStorage.setItem('bladeo_sidebar_collapsed', 'false');
      } else {
        document.documentElement.setAttribute('data-sidebar-collapsed', 'true');
        localStorage.setItem('bladeo_sidebar_collapsed', 'true');
      }
    }

    // Set correct icon for collapse button on load
    (function() {
      // Collapse icon rotation is handled by CSS transition on #collapse-icon
    })();

    // ── Close all dropdowns helper ────────────────────────────────────────────
    function closeAllDropdowns() {
      var ids = ['notif-dropdown', 'quick-action-menu', 'avatar-dropdown'];
      ids.forEach(function(id) {
        var el = document.getElementById(id);
        if (el) el.classList.add('hidden');
      });
    }

    // Close dropdowns on outside click
    document.addEventListener('click', function(e) {
      var notifBtn = document.getElementById('notif-btn');
      var notifDd = document.getElementById('notif-dropdown');
      var qaBtn   = document.getElementById('quick-action-btn');
      var qaDd    = document.getElementById('quick-action-menu');
      var avatBtn = document.getElementById('avatar-btn');
      var avatDd  = document.getElementById('avatar-dropdown');

      if (notifDd && !notifDd.classList.contains('hidden')) {
        if (!notifBtn.contains(e.target) && !notifDd.contains(e.target)) {
          notifDd.classList.add('hidden');
        }
      }
      if (qaDd && !qaDd.classList.contains('hidden')) {
        if (!qaBtn.contains(e.target) && !qaDd.contains(e.target)) {
          qaDd.classList.add('hidden');
        }
      }
      if (avatDd && !avatDd.classList.contains('hidden')) {
        if (!avatBtn.contains(e.target) && !avatDd.contains(e.target)) {
          avatDd.classList.add('hidden');
        }
      }
    });

    // ── Feature #1: Notifications ─────────────────────────────────────────────
    var _notifications = [];

    function toggleNotifDropdown(e) {
      e.stopPropagation();
      var dd = document.getElementById('notif-dropdown');
      var qadd = document.getElementById('quick-action-menu');
      var avdd = document.getElementById('avatar-dropdown');
      if (qadd) qadd.classList.add('hidden');
      if (avdd) avdd.classList.add('hidden');
      dd.classList.toggle('hidden');
    }

    function markAllNotifsRead() {
      var now = new Date().toISOString();
      localStorage.setItem('bladeo_notif_read', now);
      updateNotifBadge();
      renderNotifList();
    }

    function timeAgo(dateStr) {
      var diff = Date.now() - new Date(dateStr).getTime();
      var mins = Math.floor(diff / 60000);
      if (mins < 1) return 'ahora';
      if (mins < 60) return 'hace ' + mins + ' min';
      var hrs = Math.floor(mins / 60);
      if (hrs < 24) return 'hace ' + hrs + 'h';
      var days = Math.floor(hrs / 24);
      return 'hace ' + days + 'd';
    }

    function getNotifTypeIcon(type) {
      if (type === 'appointment' || type === 'booking') {
        return '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>';
      }
      if (type === 'payment') {
        return '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2"></rect><circle cx="12" cy="12" r="2"></circle><path d="M6 12h.01M18 12h.01"></path></svg>';
      }
      return '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>';
    }

    function renderNotifList() {
      var container = document.getElementById('notif-list');
      if (!container) return;
      var lastRead = localStorage.getItem('bladeo_notif_read');
      var lastReadTime = lastRead ? new Date(lastRead).getTime() : 0;

      if (_notifications.length === 0) {
        container.innerHTML = '<p class="text-[var(--color-text-secondary)] text-sm text-center py-6">Sin notificaciones</p>';
        return;
      }

      var shown = _notifications.slice(0, 8);
      container.innerHTML = shown.map(function(n) {
        var isNew = lastReadTime === 0 || new Date(n.created_at || n.time || n.timestamp || '').getTime() > lastReadTime;
        var agendaUrl = '/app/agenda' + (n.date ? '?date=' + n.date : '');
        return '<a href="' + agendaUrl + '" class="flex items-start gap-3 px-4 py-3 hover:bg-[var(--color-surface-elevated)] transition-colors" style="text-decoration:none;" onclick="closeAllDropdowns()">'
          + '<div class="flex-shrink-0 mt-0.5 w-6 h-6 rounded-full bg-[var(--color-brand)]/20 text-[var(--color-brand-light)] flex items-center justify-center">'
          + getNotifTypeIcon(n.type)
          + '</div>'
          + '<div class="flex-1 min-w-0">'
          + '<div class="flex items-start justify-between gap-2">'
          + '<p class="text-sm font-medium text-white leading-tight">' + (n.title || 'Notificación') + '</p>'
          + (isNew ? '<span class="flex-shrink-0 w-2 h-2 rounded-full bg-red-500 mt-1"></span>' : '')
          + '</div>'
          + (n.body ? '<p class="text-xs text-[var(--color-text-secondary)] mt-0.5 leading-relaxed">' + n.body + '</p>' : '')
          + '<p class="text-[11px] text-[#555568] mt-1">' + timeAgo(n.created_at || n.time || n.timestamp || '') + ' · <span style="color:var(--color-brand-light)">Ver agenda →</span></p>'
          + '</div>'
          + '</a>';
      }).join('');
    }

    function updateNotifBadge() {
      var badge = document.getElementById('notif-badge');
      if (!badge) return;
      var lastRead = localStorage.getItem('bladeo_notif_read');
      var lastReadTime = lastRead ? new Date(lastRead).getTime() : 0;
      var unread = _notifications.filter(function(n) {
        var t = new Date(n.created_at || n.time || n.timestamp || '').getTime();
        return t > lastReadTime;
      });
      if (unread.length > 0) {
        badge.textContent = unread.length > 99 ? '99+' : String(unread.length);
        badge.classList.remove('hidden');
        badge.classList.add('flex');
      } else {
        badge.classList.add('hidden');
        badge.classList.remove('flex');
      }
    }

    // Persist known notification IDs in localStorage so they survive across tabs/sessions.
    // This prevents re-showing toasts for old notifications every time the app is opened.
    var _knownNotifIds = null;
    try {
      var _stored = localStorage.getItem('_bladeo_notif_ids');
      if (_stored) _knownNotifIds = JSON.parse(_stored);
    } catch(e) {}

    function fetchNotifications() {
      fetch('/api/notifications')
        .then(function(r) { return r.ok ? r.json() : []; })
        .then(function(data) {
          _notifications = Array.isArray(data) ? data : (data.notifications || []);
          updateNotifBadge();

          // Detect newly arrived notifications and trigger toast + sound
          if (_knownNotifIds !== null) {
            var newOnes = _notifications.filter(function(n) {
              return _knownNotifIds.indexOf(n.id) === -1;
            });
            if (newOnes.length > 0) {
              var newest = newOnes[0]; // API returns DESC order, so index 0 is newest
              showBookingToast({
                clientName: newest.body ? newest.body.split(' — ')[0] : newest.title,
                time: newest.time,
                date: newest.date,
                appointmentId: newest.id,
              });
              playNotifSound();
              // Immediately mark the shown notification as known so it won't re-appear
              _knownNotifIds = (_knownNotifIds || []).concat([newest.id]);
              try { localStorage.setItem('_bladeo_notif_ids', JSON.stringify(_knownNotifIds)); } catch(e) {}
            }
          }
          // Merge all current IDs into known list (cap at 200 to avoid unbounded growth)
          var _allIds = _notifications.map(function(n) { return n.id; });
          var _merged = _allIds.slice();
          (_knownNotifIds || []).forEach(function(id) { if (_merged.indexOf(id) === -1) _merged.push(id); });
          _knownNotifIds = _merged.slice(0, 200);
          try { localStorage.setItem('_bladeo_notif_ids', JSON.stringify(_knownNotifIds)); } catch(e) {}

          // Re-render if dropdown is open
          var dd = document.getElementById('notif-dropdown');
          if (dd && !dd.classList.contains('hidden')) {
            renderNotifList();
          }
        })
        .catch(function() {});
    }

    // ── Notification sound ───────────────────────────────────────────────────
    // Keep a single AudioContext — browsers block new ones without a user gesture
    var _audioCtx = null;
    document.addEventListener('click', function() {
      try {
        if (!_audioCtx) _audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        else if (_audioCtx.state === 'suspended') _audioCtx.resume().catch(function(){});
      } catch(e) {}
    }, { passive: true });

    function _playTone(ctx, freq, startTime, duration) {
      var osc = ctx.createOscillator();
      var gain = ctx.createGain();
      osc.connect(gain);
      gain.connect(ctx.destination);
      osc.type = 'sine';
      osc.frequency.setValueAtTime(freq, startTime);
      gain.gain.setValueAtTime(0, startTime);
      gain.gain.linearRampToValueAtTime(0.3, startTime + 0.01);
      gain.gain.exponentialRampToValueAtTime(0.001, startTime + duration);
      osc.start(startTime);
      osc.stop(startTime + duration);
    }

    function playNotifSound() {
      try {
        var sound = 'bladeo';
        try { sound = localStorage.getItem('_bladeo_notif_sound') || 'bladeo'; } catch(e) {}

        // Custom audio file stored as base64 data URL
        if (sound === 'custom') {
          try {
            var dataUrl = localStorage.getItem('_bladeo_notif_sound_custom');
            if (dataUrl) { new Audio(dataUrl).play(); return; }
          } catch(e) {}
          sound = 'bladeo'; // fallback if no data
        }

        if (!_audioCtx) _audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        var ctx = _audioCtx;
        var doPlay = function() {
          var t = ctx.currentTime;
          if (sound === 'campana') {
            _playTone(ctx, 1046, t,        0.40);
            _playTone(ctx, 880,  t + 0.30, 0.50);
          } else if (sound === 'triple') {
            _playTone(ctx, 1000, t,        0.12);
            _playTone(ctx, 1000, t + 0.16, 0.12);
            _playTone(ctx, 1200, t + 0.32, 0.18);
          } else if (sound === 'suave') {
            _playTone(ctx, 528, t, 0.60);
          } else {
            _playTone(ctx, 880,     t,        0.25);
            _playTone(ctx, 1174.66, t + 0.18, 0.30);
          }
        };
        if (ctx.state === 'suspended') ctx.resume().then(doPlay).catch(function(){});
        else doPlay();
      } catch(e) {}
    }

    // ── Booking toast (top-left banner) ─────────────────────────────────────
    function showBookingToast(data) {
      var toast = document.getElementById('booking-toast');
      var inner = document.getElementById('booking-toast-inner');
      var body  = document.getElementById('booking-toast-body');
      var bar   = document.getElementById('booking-toast-bar');
      var link  = document.getElementById('booking-toast-link');
      if (!toast || !inner || !body) return;

      // Update link to open the agenda on the correct date
      if (link) {
        var agendaUrl = '/app/agenda';
        if (data.date) agendaUrl += '?date=' + data.date;
        link.setAttribute('href', agendaUrl);
      }

      body.textContent = (data.clientName || 'Cliente') + (data.time ? ' · ' + data.time : '');

      // Reset bar without transition, then animate
      if (bar) { bar.style.transition = 'none'; bar.style.transform = 'scaleX(1)'; }

      toast.style.display = 'block';
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          inner.style.opacity = '1';
          inner.style.transform = 'translateY(0px)';
          if (bar) {
            bar.style.transition = 'transform 8s linear';
            bar.style.transform = 'scaleX(0)';
          }
        });
      });

      clearTimeout(window._bookingToastTimer);
      window._bookingToastTimer = setTimeout(dismissBookingToast, 8000);
    }

    function dismissBookingToast() {
      clearTimeout(window._bookingToastTimer);
      var inner = document.getElementById('booking-toast-inner');
      var toast = document.getElementById('booking-toast');
      if (!inner) return;
      inner.style.opacity = '0';
      inner.style.transform = 'translateY(20px)';
      setTimeout(function() { if (toast) toast.style.display = 'none'; }, 260);
    }

    // Expose for realtime module
    window._showBookingToast = showBookingToast;
    window._dismissBookingToast = dismissBookingToast;

    // fetchNotifications now handles toast + sound internally
    window._fetchNotificationsAndSound = fetchNotifications;

    // Fallback polling (30s) — realtime module replaces this if available
    window.addEventListener('load', function() {
      fetchNotifications();
      window._notifPollingInterval = setInterval(fetchNotifications, 10000);
    });

    // Render list when dropdown opens
    var origToggleNotif = window.toggleNotifDropdown;
    window.toggleNotifDropdown = function(e) {
      origToggleNotif(e);
      var dd = document.getElementById('notif-dropdown');
      if (dd && !dd.classList.contains('hidden')) {
        renderNotifList();
      }
    };

    // ── Feature #2: Quick action + Expense modal ──────────────────────────────
    function toggleQuickAction(e) {
      e.stopPropagation();
      var dd = document.getElementById('quick-action-menu');
      var ndd = document.getElementById('notif-dropdown');
      var avdd = document.getElementById('avatar-dropdown');
      if (ndd) ndd.classList.add('hidden');
      if (avdd) avdd.classList.add('hidden');
      dd.classList.toggle('hidden');
    }

    function closeQuickAction() {
      var dd = document.getElementById('quick-action-menu');
      if (dd) dd.classList.add('hidden');
    }

    function openExpenseModal() {
      var modal = document.getElementById('expense-modal');
      // Set default date to today
      var dateInput = document.getElementById('expense-date');
      if (dateInput) {
        var today = new Date();
        var y = today.getFullYear();
        var m = String(today.getMonth() + 1).padStart(2, '0');
        var d = String(today.getDate()).padStart(2, '0');
        dateInput.value = y + '-' + m + '-' + d;
      }
      // Clear previous errors and reset form
      var errEl = document.getElementById('expense-error');
      if (errEl) errEl.classList.add('hidden');
      var form = document.getElementById('expense-form');
      if (form) form.reset();
      // Re-set date after reset
      if (dateInput) {
        var today2 = new Date();
        var y2 = today2.getFullYear();
        var m2 = String(today2.getMonth() + 1).padStart(2, '0');
        var d2 = String(today2.getDate()).padStart(2, '0');
        dateInput.value = y2 + '-' + m2 + '-' + d2;
      }
      modal.classList.remove('hidden');
    }

    function closeExpenseModal() {
      var modal = document.getElementById('expense-modal');
      modal.classList.add('hidden');
    }

    function handleExpenseModalBackdrop(e) {
      if (e.target === document.getElementById('expense-modal')) {
        closeExpenseModal();
      }
    }

    function submitExpense(e) {
      e.preventDefault();
      var form = e.target;
      var btn = document.getElementById('expense-submit-btn');
      var errEl = document.getElementById('expense-error');

      var data = {
        category:    form.category.value,
        description: form.description.value,
        amount:      parseFloat(form.amount.value),
        date:        form.date.value,
      };

      btn.disabled = true;
      btn.textContent = 'Guardando...';
      if (errEl) errEl.classList.add('hidden');

      fetch('/api/expenses', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      })
        .then(function(r) {
          return r.json().then(function(d) { return { ok: r.ok, data: d }; });
        })
        .then(function(res) {
          if (res.ok) {
            closeExpenseModal();
          } else {
            if (errEl) {
              errEl.textContent = res.data.error || 'Error al guardar el gasto.';
              errEl.classList.remove('hidden');
            }
          }
        })
        .catch(function() {
          if (errEl) {
            errEl.textContent = 'Error de conexión. Intenta de nuevo.';
            errEl.classList.remove('hidden');
          }
        })
        .finally(function() {
          btn.disabled = false;
          btn.textContent = 'Guardar gasto';
        });
    }

    // ── Feature #4: Avatar dropdown ───────────────────────────────────────────
    function toggleAvatarDropdown(e) {
      e.stopPropagation();
      var dd = document.getElementById('avatar-dropdown');
      var ndd = document.getElementById('notif-dropdown');
      var qadd = document.getElementById('quick-action-menu');
      if (ndd) ndd.classList.add('hidden');
      if (qadd) qadd.classList.add('hidden');
      dd.classList.toggle('hidden');
    }

    // ── Feature #5: Color themes ──────────────────────────────────────────────
    var _colorThemes = {
      'dark-azul':    { brand:'#2563eb', brandLight:'#3b82f6', surface:'#0a0a0f', elevated:'#12121a', overlay:'#1a1a25', border:'#2a2a3a', textPrimary:'#f0f0f5', textSecondary:'#8888a0' },
      'dark-morado':  { brand:'#7c3aed', brandLight:'#8b5cf6', surface:'#0a0a0f', elevated:'#12121a', overlay:'#1a1a25', border:'#2a2a3a', textPrimary:'#f0f0f5', textSecondary:'#8888a0' },
      'dark-verde':   { brand:'#16a34a', brandLight:'#22c55e', surface:'#0a0f0a', elevated:'#101a10', overlay:'#182518', border:'#253525', textPrimary:'#f0f5f0', textSecondary:'#80a080' },
      'dark-naranja': { brand:'#ea580c', brandLight:'#f97316', surface:'#0f0a06', elevated:'#1a1208', overlay:'#251c0e', border:'#352a1a', textPrimary:'#f5f0e8', textSecondary:'#a09070' },
      'dark-carbon':  { brand:'#6366f1', brandLight:'#818cf8', surface:'#060608', elevated:'#0f0f14', overlay:'#16161e', border:'#222230', textPrimary:'#e8e8f0', textSecondary:'#7070a0' },
      'dark-slate':   { brand:'#38bdf8', brandLight:'#7dd3fc', surface:'#080c10', elevated:'#0f1520', overlay:'#162030', border:'#1e3040', textPrimary:'#dceeff', textSecondary:'#6080a0' },
      'light-blanco': { brand:'#2563eb', brandLight:'#3b82f6', surface:'#f5f7ff', elevated:'#ffffff', overlay:'#eef1fb', border:'#d4d9f0', textPrimary:'#0f1428', textSecondary:'#5060a0' },
      'light-gris':   { brand:'#7c3aed', brandLight:'#8b5cf6', surface:'#f2f2f5', elevated:'#ffffff', overlay:'#ebebf2', border:'#d0d0de', textPrimary:'#111118', textSecondary:'#606075' },
      'light-crema':  { brand:'#b45309', brandLight:'#d97706', surface:'#fdf8f0', elevated:'#ffffff', overlay:'#f5ede0', border:'#e0d0b8', textPrimary:'#1a1008', textSecondary:'#806040' },
      'light-menta':  { brand:'#0d9488', brandLight:'#14b8a6', surface:'#f0faf8', elevated:'#ffffff', overlay:'#e0f5f0', border:'#b8e0da', textPrimary:'#051a18', textSecondary:'#407070' },
    };

    function applyTheme(name) {
      var t = _colorThemes[name];
      if (!t) return;
      var r = document.documentElement;
      r.style.setProperty('--color-brand', t.brand);
      r.style.setProperty('--color-brand-light', t.brandLight);
      r.style.setProperty('--color-surface', t.surface);
      r.style.setProperty('--color-surface-elevated', t.elevated);
      r.style.setProperty('--color-surface-overlay', t.overlay);
      r.style.setProperty('--color-border', t.border);
      r.style.setProperty('--color-text-primary', t.textPrimary);
      r.style.setProperty('--color-text-secondary', t.textSecondary);
      r.setAttribute('data-color-theme', name);
      localStorage.setItem('bladeo_theme', name);
      updateThemeButtons(name);
    }

    // applyTheme is available globally — theme buttons live in settings.astro
  </script>

  <!-- Navigation progress bar -->
  <div id="nav-progress" style="position:fixed;top:0;left:0;right:0;height:2px;background:var(--color-brand);z-index:9999;transform:scaleX(0);transform-origin:left;transition:transform 200ms ease,opacity 300ms ease;opacity:0;pointer-events:none;"></div>
  <script is:inline>
    document.addEventListener('astro:before-preparation', function() {
      var bar = document.getElementById('nav-progress');
      if (!bar) return;
      bar.style.opacity = '1';
      bar.style.transform = 'scaleX(0.4)';
      bar.style.transition = 'transform 2s ease,opacity 300ms ease';
    });
    document.addEventListener('astro:after-preparation', function() {
      var bar = document.getElementById('nav-progress');
      if (!bar) return;
      bar.style.transform = 'scaleX(0.8)';
    });
    document.addEventListener('astro:page-load', function() {
      var bar = document.getElementById('nav-progress');
      if (!bar) return;
      bar.style.transition = 'transform 150ms ease,opacity 300ms ease';
      bar.style.transform = 'scaleX(1)';
      setTimeout(function() {
        bar.style.opacity = '0';
        setTimeout(function() { bar.style.transform = 'scaleX(0)'; }, 300);
      }, 150);
    });
  </script>

  <!-- Web Push subscription -->
  <script is:inline define:vars={{ vapidKey: import.meta.env.PUBLIC_VAPID_KEY }}>
    function _urlBase64ToUint8Array(base64String) {
      var padding = '='.repeat((4 - base64String.length % 4) % 4);
      var base64 = (base64String + padding).replace(/-/g, '+').replace(/_/g, '/');
      var rawData = atob(base64);
      var outputArray = new Uint8Array(rawData.length);
      for (var i = 0; i < rawData.length; ++i) outputArray[i] = rawData.charCodeAt(i);
      return outputArray;
    }

    async function _registerPush() {
      if (!('serviceWorker' in navigator) || !('PushManager' in window)) return;
      try {
        var reg = await navigator.serviceWorker.register('/sw.js', { scope: '/', updateViaCache: 'none' });
        await navigator.serviceWorker.ready;

        var permission = Notification.permission;
        if (permission === 'default') {
          permission = await Notification.requestPermission();
        }
        if (permission !== 'granted') return;

        // Re-use existing subscription or create a new one
        var sub = await reg.pushManager.getSubscription();
        if (!sub) {
          sub = await reg.pushManager.subscribe({
            userVisibleOnly: true,
            applicationServerKey: _urlBase64ToUint8Array(vapidKey),
          });
        }

        // Only call the server if this endpoint isn't already confirmed saved
        var savedEp = localStorage.getItem('_bladeo_push_ep');
        if (savedEp !== sub.endpoint) {
          var res = await fetch('/api/push/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ subscription: sub }),
          });
          if (res.ok) {
            localStorage.setItem('_bladeo_push_ep', sub.endpoint);
          }
        }
      } catch (e) {
        // Push setup is non-critical — fail silently
      }
    }

    // Run on every load/navigation — localStorage dedup prevents unnecessary DB calls
    window.addEventListener('load', function() { setTimeout(_registerPush, 1000); });
    document.addEventListener('astro:page-load', function() { setTimeout(_registerPush, 1000); });
  </script>

  <!-- Realtime notifications via Supabase -->
  <div id="realtime-config" data-barbershop-id={barbershop?.id ?? ''} class="hidden"></div>
  <script>
    import { createClient } from '@supabase/supabase-js';

    const configEl = document.getElementById('realtime-config');
    const barbershopId = (configEl as HTMLElement | null)?.dataset?.barbershopId ?? '';

    if (barbershopId) {
      const sb = createClient(
        import.meta.env.PUBLIC_SUPABASE_URL,
        import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
        { realtime: { params: { eventsPerSecond: 2 } } }
      );

      let prevCount = 0;

      sb.channel('notif-channel')
        .on('postgres_changes', {
          event: 'INSERT',
          schema: 'public',
          table: 'appointments',
          filter: `barbershop_id=eq.${barbershopId}`,
        }, () => {
          // fetchNotifications detects new items and triggers toast + sound
          if ((window as any)._fetchNotificationsAndSound) {
            (window as any)._fetchNotificationsAndSound();
          }
          // Stop fallback polling — realtime is active
          if ((window as any)._notifPollingInterval) {
            clearInterval((window as any)._notifPollingInterval);
            (window as any)._notifPollingInterval = null;
          }
        })
        .on('postgres_changes', {
          event: 'UPDATE',
          schema: 'public',
          table: 'appointments',
          filter: `barbershop_id=eq.${barbershopId}`,
        }, () => {
          if ((window as any)._fetchNotificationsAndSound) {
            (window as any)._fetchNotificationsAndSound();
          }
        })
        .subscribe();
    }
  </script>
</body>
</html>
